<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layout/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Print Application Form' %></title>
</head>
<body>
    <%- include('../layout/header') %>
    <section>
        <div class="container my-5">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="card shadow">
                        <div class="card-header bg-primary text-white">
                            <h4 class="mb-0">Print Application Form</h4>
                        </div>
                        <div class="card-body">
                            <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                                <div class="alert alert-danger">
                                    <ul class="mb-0">
                                        <% errors.forEach(function(error) { %>
                                            <li><%= error %></li>
                                        <% }); %>
                                    </ul>
                                </div>
                            <% } %>

                            <form action="/print_application_form_show" method="GET">
                                <div class="mb-3">
                                    <label for="academic_year" class="form-label">Academic Year <span class="text-danger">*</span></label>
                                    <select name="academic_year" id="academic_year" class="form-select" required>
                                        <option value="">Select Academic Year</option>
                                        <% if (typeof academicYears !== 'undefined' && academicYears.length > 0) { %>
                                            <% academicYears.forEach(function(year) { %>
                                                <option value="<%= year.id %>" <%= (typeof activeAcademicYear !== 'undefined' && activeAcademicYear && activeAcademicYear.id === year.id) ? 'selected' : '' %>><%= year.session %></option>
                                            <% }); %>
                                        <% } %>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label for="registration_no" class="form-label">Registration Number <span class="text-danger">*</span></label>
                                    <input type="text" name="registration_no" id="registration_no" class="form-control"
                                        value="<%= typeof oldInput !== 'undefined' && oldInput.registration_no ? oldInput.registration_no : '' %>"
                                        placeholder="Enter Registration Number" required>
                                </div>

                                <div class="mb-3">
                                    <label for="dob" class="form-label">Date of Birth <span class="text-danger">*</span></label>
                                    <input type="date" name="dob" id="dob" class="form-control"
                                        value="<%= typeof oldInput !== 'undefined' && oldInput.dob ? oldInput.dob : '' %>"
                                        required>
                                </div>

                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary">Print Form</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <%- include('../layout/footer') %>
    <%- include('../layout/script_link') %>
</body>
</html>


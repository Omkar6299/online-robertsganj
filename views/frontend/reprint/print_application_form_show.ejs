<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../../layout/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Application Form Preview' %></title>
    <style>
        :root {
            --primary: #0f4c81;
            --primary-dark: #0a3559;
            --secondary: #8b1e3f;
            --accent: #c8a96a;
            --border: #cfd8e3;
            --border-dark: #9fb2c8;
            --text: #1f2937;
            --muted: #6b7280;
            --bg-soft: #f5f7fb;
            --bg-panel: #f9fbfd;
            --white: #ffffff;
            --success: #1f7a4d;
        }

        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
            color: var(--text);
            background: #eef2f7;
            line-height: 1.4;
        }

        .no-print-toolbar {
            text-align: center;
            padding: 18px 12px;
        }

        .application-sheet {
            width: 210mm;
            min-height: 297mm;
            margin: 14px auto;
            background: var(--white);
            box-shadow: 0 14px 35px rgba(15, 76, 129, 0.12);
            border: 1px solid #94a3b8;
            position: relative;
            overflow: hidden;
            font-size: 11px;
        }

        .application-sheet::before {
            content: "";
            position: absolute;
            inset: 0 0 auto 0;
            height: 10px;
            background: linear-gradient(90deg, var(--primary-dark), var(--primary), var(--secondary));
        }

        .sheet-inner {
            padding: 10mm 10mm 10mm;
        }

        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .fw-700 { font-weight: 700; }
        .fw-600 { font-weight: 600; }
        .small { font-size: 10px; }
        .muted { color: var(--muted); }
        .mb-0 { margin-bottom: 0; }
        .mt-0 { margin-top: 0; }
        .mt-8 { margin-top: 8px; }
        .mt-12 { margin-top: 12px; }
        .mt-16 { margin-top: 16px; }
        .mt-20 { margin-top: 20px; }
        .mt-24 { margin-top: 24px; }

        .top-meta {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            align-items: center;
            font-size: 10px;
            color: var(--muted);
            margin-bottom: 10px;
            padding-bottom: 6px;
            border-bottom: 1px dashed var(--border-dark);
        }

        .college-header {
            border: 1px solid var(--border-dark);
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            padding: 8px 12px;
            border-radius: 10px;
            margin-bottom: 12px;
        }

        .college-header-grid {
            display: grid;
            grid-template-columns: 70px 1fr 70px;
            gap: 12px;
            align-items: center;
        }

        .college-logo {
            width: 70px;
            height: 70px;
            object-fit: contain;
        }

        .college-name-en {
            margin: 0;
            color: var(--primary-dark);
            font-size: 20px;
            line-height: 1.2;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .college-name-hi {
            margin: 4px 0 0;
            color: var(--secondary);
            font-size: 16px;
            line-height: 1.25;
            font-weight: 700;
        }

        .college-subtitle {
            margin-top: 6px;
            font-size: 11px;
            color: var(--muted);
            font-weight: 600;
        }

        .title-ribbon-wrap {
            text-align: center;
            margin-top: 12px;
        }

        .title-ribbon {
            display: inline-block;
            padding: 7px 20px;
            background: linear-gradient(90deg, var(--primary), var(--primary-dark));
            color: #fff;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            box-shadow: 0 6px 14px rgba(15, 76, 129, 0.18);
        }

        .summary-band {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            margin: 10px 0 12px;
        }

        .summary-card {
            border: 1px solid #cbd5e1;
            background: var(--bg-panel);
            border-radius: 8px;
            padding: 5px 10px;
            min-height: 52px;
        }

        .summary-card .label {
            font-size: 10px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .summary-card .value {
            font-size: 13px;
            font-weight: 700;
            color: var(--primary-dark);
            word-break: break-word;
        }

        .section-card {
            border: 1px solid #94a3b8;
            border-radius: 10px;
            margin-top: 10px;
            overflow: hidden;
            background: #fff;
        }

        .section-head {
            padding: 6px 14px;
            background: linear-gradient(90deg, rgba(15, 76, 129, 0.08), rgba(139, 30, 63, 0.06));
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .section-title {
            margin: 0;
            font-size: 13px;
            font-weight: 800;
            color: var(--primary-dark);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .section-subtitle {
            font-size: 10px;
            color: var(--muted);
        }

        .section-body {
            padding: 8px 14px;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 16px;
        }

        .grid-2-equal {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px 16px;
        }

        .info-item {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 4px;
            min-height: 25px;
        }

        .info-label {
            width: 44%;
            color: #4b5563;
            font-weight: 600;
        }

        .info-value {
            width: 56%;
            color: #111827;
            font-weight: 700;
            word-break: break-word;
        }

        .info-value::before {
            content: ':';
            margin-right: 8px;
            color: #4b5563;
            font-weight: 500;
        }

        .profile-panel {
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px;
            background: var(--bg-soft);
            height: 100%;
        }

        .photo-sign-stack {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-bottom: 14px;
        }

        .asset-box {
            width: 120px;
            border: 1px solid var(--border-dark);
            border-radius: 10px;
            background: #fff;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(15, 76, 129, 0.05);
        }

        .asset-label {
            background: var(--primary);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            text-align: center;
            padding: 5px 4px;
            letter-spacing: 0.4px;
        }

        .asset-image {
            height: 118px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            padding: 6px;
        }

        .asset-sign {
            height: 54px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            padding: 6px;
            border-top: 1px solid var(--border);
        }

        .asset-image img,
        .asset-sign img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .placeholder-text {
            font-size: 10px;
            color: #9ca3af;
        }

        .badge-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 10px;
        }

        .mini-badge {
            border: 1px solid #cbd5e1;
            background: #fff;
            border-radius: 8px;
            padding: 5px 10px;
        }

        .mini-badge .label {
            font-size: 10px;
            color: var(--muted);
            margin-bottom: 3px;
        }

        .mini-badge .value {
            font-size: 12px;
            font-weight: 700;
        }

        .subject-box {
            border: 1px solid #cbd5e1;
            padding: 8px 10px;
            border-radius: 8px;
            background: #fcfdfe;
            margin-top: 12px;
        }

        .subject-title {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: var(--primary-dark);
            font-weight: 800;
            margin-bottom: 8px;
        }

        .subject-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px 16px;
            font-size: 11px;
        }

        .subject-grid div span {
            color: var(--muted);
            font-weight: 600;
        }

        table.data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }

        .data-table th,
        .data-table td {
            border: 1px solid var(--border);
            padding: 7px 8px;
            text-align: left;
            vertical-align: top;
        }

        .data-table thead th {
            background: #eef4fb;
            color: var(--primary-dark);
            font-weight: 800;
            font-size: 10.5px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .weightage-list {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px 16px;
        }

        .weightage-item {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 8px 10px;
            background: var(--bg-panel);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 54px;
            padding: 2px 10px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            border: 1px solid transparent;
        }

        .status-yes {
            color: var(--success);
            background: rgba(31, 122, 77, 0.1);
            border-color: rgba(31, 122, 77, 0.2);
        }

        .status-no {
            color: #9b1c1c;
            background: rgba(155, 28, 28, 0.08);
            border-color: rgba(155, 28, 28, 0.15);
        }

        .documents-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px 14px;
        }

        .document-chip {
            border: 1px solid var(--border);
            border-left: 4px solid var(--accent);
            border-radius: 10px;
            padding: 8px 10px;
            background: #fff;
            font-weight: 600;
            color: #374151;
        }

        .undertaking-box {
            border: 1px solid var(--border-dark);
            border-radius: 14px;
            padding: 14px;
            background: linear-gradient(180deg, #fffefb 0%, #ffffff 100%);
        }

        .undertaking-box ol {
            margin: 8px 0 0;
            padding-left: 18px;
        }

        .undertaking-box li {
            margin-bottom: 6px;
            text-align: justify;
        }

        .highlight-box {
            margin-top: 14px;
            border: 1px solid rgba(139, 30, 63, 0.2);
            background: rgba(139, 30, 63, 0.04);
            border-radius: 12px;
            padding: 12px;
        }

        .signature-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-top: 24px;
            align-items: end;
        }

        .signature-box {
            text-align: center;
        }

        .signature-line {
            border-top: 1px solid #111827;
            margin-top: 36px;
            padding-top: 5px;
            font-weight: 700;
        }

        .instruction-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px 18px;
            font-size: 11px;
        }

        .receipt-cut {
            border-top: 2px dashed #111827;
            margin: 24px 0;
        }

        .receipt-panel {
            border: 1px solid var(--border-dark);
            border-radius: 14px;
            overflow: hidden;
        }

        .receipt-header {
            background: linear-gradient(90deg, var(--primary), var(--primary-dark));
            color: #fff;
            text-align: center;
            padding: 8px 10px;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.4px;
        }

        .receipt-body {
            padding: 14px;
            background: #fff;
        }

        .receipt-footer {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-top: 18px;
            align-items: end;
        }

        .footer-mini-header {
            margin-top: 16px;
            padding-top: 12px;
            border-top: 1px dashed var(--border-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            color: var(--primary-dark);
            font-weight: 700;
        }

        .empty-state {
            padding: 50px 20px;
            text-align: center;
            color: #b91c1c;
            font-weight: 700;
        }

        @media print {
            @page {
                size: A4;
                margin: 8mm 0;
            }
            body {
                margin: 0 !important;
                padding: 0 !important;
                background: #fff;
            }

            .no-print,
            .no-print-toolbar {
                display: none !important;
            }

            .application-sheet {
                margin: 0;
                width: 100%;
                min-height: auto;
                box-shadow: none;
                border: 1px solid #000;
                border-radius: 0;
            }

            .application-sheet::before { display: none; }

            .sheet-inner {
                padding: 8mm 10mm 10mm;
            }

            .section-card {
                margin-top: 8px;
                border-radius: 8px;
                break-inside: avoid;
                page-break-inside: avoid;
            }

            .section-head {
                padding: 6px 10px;
            }

            .section-body {
                padding: 8px 10px;
            }

            .summary-band {
                margin: 10px 0 10px;
                gap: 6px;
            }

            .subject-box,
            .receipt-panel,
            .summary-card {
                break-inside: avoid;
                page-break-inside: avoid;
            }

            .section-card,
            .undertaking-box,
            .receipt-panel,
            .college-header,
            .summary-card,
            .profile-panel,
            .weightage-item,
            .document-chip {
                break-inside: avoid;
                page-break-inside: avoid;
            }
        }

        @media (max-width: 900px) {
            .application-sheet {
                width: calc(100% - 20px);
            }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <%- include('../../layout/header') %>
    </div>

    <div class="no-print-toolbar no-print">
        <button onclick="window.print()" class="btn btn-primary btn-sm">
            <i class="bi bi-printer"></i> Print Application
        </button>
        <a href="/" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
    </div>

    <div class="application-sheet">
        <div class="sheet-inner">
            <% if (typeof student !== 'undefined' && student) { %>
                <%
                    let formattedRegDate = '-';
                    if (typeof payment !== 'undefined' && payment) {
                        if (payment.txnCompleteDate) {
                            formattedRegDate = new Date(payment.txnCompleteDate).toLocaleDateString('en-IN');
                        } else if (payment.transaction_date) {
                            formattedRegDate = new Date(payment.transaction_date).toLocaleDateString('en-IN');
                        } else if (payment.created_at) {
                            formattedRegDate = new Date(payment.created_at).toLocaleDateString('en-IN');
                        }
                    } else if (student.createdAt) {
                        formattedRegDate = new Date(student.createdAt).toLocaleDateString('en-IN');
                    }

                    let claimedWeightageIds = [];
                    let studentWeightageObj = student.weightage;
                    if (typeof studentWeightageObj === 'string') {
                        try { studentWeightageObj = JSON.parse(studentWeightageObj); } catch (e) {}
                    }
                    if (studentWeightageObj) {
                        Object.keys(studentWeightageObj).forEach(key => {
                            if (studentWeightageObj[key] === '1' || studentWeightageObj[key] === true) {
                                claimedWeightageIds.push(key.toString());
                            }
                        });
                    }

                    let filteredDocs = [];
                    if (typeof student.documents !== 'undefined' && student.documents.length > 0) {
                        filteredDocs = student.documents.filter(doc => {
                            const code = doc.documentType ? doc.documentType.code : '';
                            return !['photo', 'signature', 'sign'].includes(code);
                        });
                    }
                %>

                <div class="top-meta">
                    <div>Generated On: <strong><%= new Date().toLocaleString('en-IN') %></strong></div>
                    <div>Institution: <strong><%= fieldLabels.header.college_name_en %></strong></div>
                </div>

                <div class="college-header">
                    <div class="college-header-grid">
                        <div class="text-center">
                            <img src="/uploads/static/logo_header.png" alt="College Logo" class="college-logo">
                        </div>
                        <div class="text-center">
                            <h1 class="college-name-en">Government Women Degree College Robertsganj Sonebhadra</h1>
                            <div class="college-name-hi">राजकीय महिला महाविद्यालय रॉबर्ट्सगंज सोनभद्र</div>
                            <div class="college-subtitle">Affiliated to Mahatma Gandhi Kashi Vidyapeeth, Varanasi</div>
                        </div>
                        <div class="text-center">
                            <img src="/uploads/static/logo_header_right.png" alt="College Logo" class="college-logo">
                        </div>
                    </div>
                    <div class="title-ribbon-wrap">
                        <div class="title-ribbon">
                            <%= fieldLabels.header.application_title %> | Session: <%= activeAcademicYear ? activeAcademicYear.session : '' %>
                        </div>
                    </div>
                </div>

                <div class="summary-band">
                    <div class="summary-card">
                        <div class="label">Registration No.</div>
                        <div class="value"><%= student.registration_no || '-' %></div>
                    </div>
                    <div class="summary-card">
                        <div class="label">Application Date</div>
                        <div class="value"><%= formattedRegDate %></div>
                    </div>
                    <div class="summary-card">
                        <div class="label">Course / Semester</div>
                        <div class="value"><%= student.courseName ? student.courseName.name : '' %> - <%= student.semsterName ? student.semsterName.name : '' %></div>
                    </div>
                    <div class="summary-card">
                        <div class="label">Transaction ID</div>
                        <div class="value"><%= student.user ? student.user.transaction_id : '-' %></div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h2 class="section-title">Student Profile</h2>
                        <span class="section-subtitle">Primary applicant information</span>
                    </div>
                    <div class="section-body">
                        <div class="grid-2">
                            <div>
                                <div class="info-grid">
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.name %></div><div class="info-value"><%= student.user ? student.user.name : '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.dob %></div><div class="info-value"><%= student.dob || '-' %></div></div>
                                    <div class="info-item"><div class="info-label">Contact No.</div><div class="info-value"><%= student.user ? student.user.phone : '-' %></div></div>
                                    <div class="info-item"><div class="info-label">Email Id</div><div class="info-value"><%= student.user ? student.user.email : '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.gender %></div><div class="info-value"><%= student.gender || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.category %></div><div class="info-value"><%= student.category || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.religion %></div><div class="info-value"><%= student.religion || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.father_name %></div><div class="info-value"><%= student.father_name || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.mother_name %></div><div class="info-value"><%= student.mother_name || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.local_guardian %></div><div class="info-value"><%= student.local_guadian || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.guardian_contact %></div><div class="info-value"><%= student.guadian_contact || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.family_income %></div><div class="info-value"><%= student.family_annual_income || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.computer_literate %></div><div class="info-value"><%= student.computer_literate || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.adhar_no %></div><div class="info-value"><%= student.adhar_no || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.samarth_no %></div><div class="info-value"><%= student.samarth_no || '-' %></div></div>
                                    <% if (student.year_gap === 'Yes') { %>
                                        <div class="info-item"><div class="info-label">Gap Years</div><div class="info-value"><%= student.year_gap_after_inter || '-' %> Years</div></div>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.gap_reason %></div><div class="info-value"><%= student.gap_reason || '-' %></div></div>
                                    <% } else { %>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.year_gap %></div><div class="info-value">No</div></div>
                                    <% } %>
                                </div>

                                <div class="subject-box">
                                    <div class="subject-title">Subject Selection</div>
                                    <div class="subject-grid">
                                        <% if (student.semsterName && student.semsterName.is_major1_enabled == 1) { %>
                                            <div><span>Major 1:</span> <strong><%= (student.major1 && student.major1.subject_name) ? student.major1.subject_name : 'N/A' %></strong></div>
                                        <% } %>
                                        
                                        <% if (student.semsterName && student.semsterName.is_major2_enabled == 1) { %>
                                            <div><span>Major 2:</span> <strong><%= (student.major2 && student.major2.subject_name) ? student.major2.subject_name : 'N/A' %></strong></div>
                                        <% } %>
                                        
                                        <% if (student.semsterName && student.semsterName.is_minor_enabled == 1) { %>
                                            <div><span>Minor:</span> <strong><%= (student.minor && student.minor.subject_name) ? student.minor.subject_name : 'N/A' %></strong></div>
                                        <% } %>
                                        
                                        <% if (student.semsterName && student.semsterName.is_research_project_enabled == 1) { %>
                                            <div><span>Research Project:</span> <strong><%= (student.researchProject && student.researchProject.subject_name) ? student.researchProject.subject_name : 'N/A' %></strong></div>
                                        <% } %>

                                        <% if (student.semsterName && (student.semsterName.is_skill_required == 1 || student.semsterName.is_skill_required == '1')) { %>
                                            <div><span>Skill:</span> <strong><%= (student.skill && student.skill.name) ? student.skill.name : 'N/A' %></strong></div>
                                        <% } %>

                                        <% if (student.semsterName && (student.semsterName.is_cocurricular_required == 1 || student.semsterName.is_cocurricular_required == '1')) { %>
                                            <div><span>Co-Curricular:</span> <strong><%= (student.cocurricular && student.cocurricular.name) ? student.cocurricular.name : 'N/A' %></strong></div>
                                        <% } %>
                                        
                                        <div><span>Prev. Student:</span> <strong><%= student.is_previous_student || 'No' %></strong></div>
                                    </div>
                                </div>

                                <div class="subject-box" style="margin-top: 8px;">
                                    <div class="subject-title">Bank Account Details</div>
                                    <div class="info-grid" style="grid-template-columns: repeat(3, 1fr); gap: 10px;">
                                        <div class="info-item">
                                            <div class="info-label"><%= fieldLabels.application.fields.bank_name %></div>
                                            <div class="info-value"><%= student.bank_name || '-' %></div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label">Account No</div>
                                            <div class="info-value"><%= student.bank_account_no || '-' %></div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label">IFSC Code</div>
                                            <div class="info-value"><%= student.ifsc_code || '-' %></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <div class="profile-panel">
                                    <div class="photo-sign-stack">
                                        <div class="asset-box">
                                            <div class="asset-label">Photograph</div>
                                            <div class="asset-image">
                                                <% if (student.photo) { %>
                                                    <img src="<%= student.photo %>?t=<%= Date.now() %>" alt="Student Photo">
                                                <% } else { %>
                                                    <span class="placeholder-text">No Photo</span>
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="asset-box">
                                            <div class="asset-label" style="background: #4b5563;">Signature</div>
                                            <div class="asset-sign">
                                                <% if (student.sign) { %>
                                                    <img src="<%= student.sign %>?t=<%= Date.now() %>" alt="Student Signature">
                                                <% } else { %>
                                                    <span class="placeholder-text">No Signature</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="badge-row">
                                        <div class="mini-badge">
                                            <div class="label">Academic Session</div>
                                            <div class="value"><%= activeAcademicYear ? activeAcademicYear.session : '-' %></div>
                                        </div>
                                        <div class="mini-badge">
                                            <div class="label">Admission Status</div>
                                            <div class="value" style="color: #0f4c81"><%= student.admission_status || 'Pending' %></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Educational Qualifications</h3>
                        <div class="section-subtitle">Academic history details</div>
                    </div>
                    <div class="section-body">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Class / Level</th>
                                    <th>School / College Name</th>
                                    <th>Board / University</th>
                                    <th>Year</th>
                                    <th>Roll No</th>
                                    <th>Marks / CGPA</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof educationals !== 'undefined' && educationals.length > 0) { %>
                                    <% educationals.forEach((edu) => { %>
                                        <tr>
                                            <td class="fw-700"><%= edu.qualification ? edu.qualification.name : edu.class_name %></td>
                                            <td><%= edu.school_name || '-' %></td>
                                            <td><%= edu.board_name || '-' %></td>
                                            <td><%= edu.year_of_passing || '-' %></td>
                                            <td><%= edu.roll_no || '-' %></td>
                                            <td>
                                                <% if (edu.mark_type === 'CGPA') { %>
                                                    <%= edu.cgpa || '-' %> (CGPA)
                                                <% } else { %>
                                                    <%= edu.obtained_marks || '0' %> / <%= edu.total_marks || '0' %> (<%= edu.percentage || '0' %>%)
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr><td colspan="6" class="text-center">No educational records found.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Weightage Details</h3>
                        <div class="section-subtitle">Additional merit claims</div>
                    </div>
                    <div class="section-body">
                        <div class="weightage-list">
                            <% if (typeof weightages !== 'undefined' && weightages.length > 0) { %>
                                <% weightages.forEach((w) => { %>
                                    <div class="weightage-item">
                                        <span class="fw-600"><%= w.name %></span>
                                        <% if (claimedWeightageIds.includes(w.id.toString())) { %>
                                            <span class="status-pill status-yes">YES</span>
                                        <% } else { %>
                                            <span class="status-pill status-no">NO</span>
                                        <% } %>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Address Details</h3>
                        <div class="section-subtitle">Mailing and permanent residence</div>
                    </div>
                    <div class="section-body">
                        <div class="grid-2-equal">
                            <div class="info-grid" style="grid-template-columns: 1fr;">
                                <div class="fw-800 muted small mb-0" style="border-bottom: 2px solid var(--accent); display: inline-block;">MAILING ADDRESS</div>
                                <div class="info-item"><div class="info-label" style="width:30%">Address</div><div class="info-value" style="width:70%"><%= student.mailing_address || '-' %></div></div>
                                <div class="info-item"><div class="info-label" style="width:30%">State/Dist</div><div class="info-value" style="width:70%"><%= student.mailing_state || '-' %> / <%= student.mailing_district || '-' %></div></div>
                                <div class="info-item"><div class="info-label" style="width:30%">Tehsil/Pin</div><div class="info-value" style="width:70%"><%= student.mailing_tehsil || '-' %> / <%= student.mailing_pincode || '-' %></div></div>
                            </div>
                            <div class="info-grid" style="grid-template-columns: 1fr;">
                                <div class="fw-800 muted small mb-0" style="border-bottom: 2px solid var(--accent); display: inline-block;">PERMANENT ADDRESS</div>
                                <div class="info-item"><div class="info-label" style="width:30%">Address</div><div class="info-value" style="width:70%"><%= student.permanent_address || '-' %></div></div>
                                <div class="info-item"><div class="info-label" style="width:30%">State/Dist</div><div class="info-value" style="width:70%"><%= student.permanent_state || '-' %> / <%= student.permanent_district || '-' %></div></div>
                                <div class="info-item"><div class="info-label" style="width:30%">Tehsil/Pin</div><div class="info-value" style="width:70%"><%= student.permanent_tehsil || '-' %> / <%= student.permanent_pincode || '-' %></div></div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="page-break">

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Declaration & Undertaking</h3>
                        <div class="section-subtitle">Applicant commitment</div>
                    </div>
                    <div class="section-body">
                        <div class="undertaking-box">
                            <p class="fw-700 mb-0">घोषणा (Declaration):</p>
                            <ol class="small">
                                <li>मैं प्रमाणित करती हूँ कि इस आवेदन पत्र में दी गई सभी सूचनाएं सत्य और सही हैं।</li>
                                <li>मैंने महाविद्यालय की नियमावली पढ़ ली है और मैं उसका पालन करने के लिए बाध्य हूँ।</li>
                                <li>यदि मेरे द्वारा दी गई कोई भी सूचना गलत पाई जाती है, तो मेरा प्रवेश बिना किसी सूचना के निरस्त किया जा सकता है।</li>
                                <li>मैं शपथ लेती हूँ कि मैं महाविद्यालय परिसर में अनुशासन बनाए रखूंगी और किसी भी रैगिंग या अवांछित गतिविधि में शामिल नहीं होऊंगी।</li>
                            </ol>

                            <div class="highlight-box mt-16">
                                <p class="mb-0 small"><strong>Note:</strong> Please bring all original documents (Marksheets, Certificates, Aadhar, etc.) along with 2 sets of photocopies at the time of physical verification in college.</p>
                            </div>
                        </div>

                        <div class="signature-row">
                            <div class="signature-box">
                                <div class="signature-line">Guardian Signature</div>
                            </div>
                            <div class="signature-box">
                                <div class="signature-line">Student Signature</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="receipt-cut"></div>

                <div class="receipt-panel">
                    <div class="receipt-header">STUDENT ADMISSION SLIP (COLLEGE COPY) - SESSION <%= activeAcademicYear ? activeAcademicYear.session : '-' %></div>
                    <div class="receipt-body">
                        <div class="grid-2-equal">
                            <div class="info-grid" style="grid-template-columns: 1fr;">
                                <div class="info-item"><div class="info-label">Student Name</div><div class="info-value"><%= student.user ? student.user.name : '-' %></div></div>
                                <div class="info-item"><div class="info-label">Father's Name</div><div class="info-value"><%= student.father_name || '-' %></div></div>
                                <div class="info-item"><div class="info-label">Registration No</div><div class="info-value"><%= student.registration_no || '-' %></div></div>
                            </div>
                            <div class="info-grid" style="grid-template-columns: 1fr;">
                                <div class="info-item"><div class="info-label">Course Name</div><div class="info-value"><%= student.courseName ? student.courseName.name : '-' %></div></div>
                                <div class="info-item"><div class="info-label">Semester</div><div class="info-value"><%= student.semsterName ? student.semsterName.name : '-' %></div></div>
                                <div class="info-item"><div class="info-label">Category</div><div class="info-value"><%= student.category || '-' %></div></div>
                            </div>
                        </div>

                        <div class="footer-mini-header">
                            <img src="/uploads/static/logo_header.png" style="height: 18px">
                            <%= fieldLabels.header.college_name_en %>
                        </div>

                        <div class="receipt-footer">
                            <div class="small muted">Date: <%= new Date().toLocaleDateString('en-IN') %></div>
                            <div class="text-right">
                                <div style="height: 40px;"></div>
                                <div class="fw-700" style="border-top: 1px solid #000; display: inline-block; padding-top: 2px;">Admission In-charge Signature</div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <i class="bi bi-exclamation-triangle" style="font-size: 3rem"></i>
                    <h3>Student Data Not Found</h3>
                    <p>We couldn't retrieve the application details. Please contact the administrator.</p>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>

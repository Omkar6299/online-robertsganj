<!DOCTYPE html>
<html lang="en">
<head>
    <% if (typeof layout !== 'undefined' && layout === 'frontend') { %>
        <%- include('../../../frontend/layout/css_link') %>
    <% } else { %>
        <%- include('../../layout/css_link') %>
    <% } %>
    <title><%= typeof title !== 'undefined' ? title : 'Application Form Preview' %></title>
    <style>
        :root {
            --primary: #0f4c81;
            --primary-dark: #0a3559;
            --secondary: #8b1e3f;
            --accent: #c8a96a;
            --border: #d1d9e6;
            --border-dark: #9fb2c8;
            --text: #1f2937;
            --muted: #6b7280;
            --bg-soft: #f5f7fb;
            --bg-panel: #f9fbfd;
            --white: #ffffff;
            --success: #1f7a4d;
        }

        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
            color: var(--text);
            background: #dde3ed;
            line-height: 1.35;
        }

        .application-sheet {
            font-size: 9.5px;
        }

        .no-print-toolbar {
            text-align: center;
            padding: 14px 12px;
        }

        /* ─── PAGE SHEET ─────────────────────────────── */
        .application-sheet {
            width: 210mm;
            margin: 12px auto;
            background: var(--white);
            box-shadow: 0 10px 30px rgba(15,76,129,0.13);
            border: 1px solid #94a3b8;
            position: relative;
            overflow: hidden;
        }

        .application-sheet::before {
            content: "";
            position: absolute;
            inset: 0 0 auto 0;
            height: 5px;
            background: linear-gradient(90deg, var(--primary-dark), var(--primary), var(--secondary));
        }

        .sheet-inner {
            padding: 5mm 8mm 6mm;
        }

        /* ─── UTILITIES ──────────────────────────────── */
        .text-center { text-align: center; }
        .fw-700 { font-weight: 700; }
        .fw-600 { font-weight: 600; }
        .muted { color: var(--muted); }
        .mb-0 { margin-bottom: 0; }

        /* ─── TOP META ───────────────────────────────── */
        .top-meta {
            display: flex;
            justify-content: space-between;
            font-size: 8.5px;
            color: var(--muted);
            margin-bottom: 5px;
            padding-bottom: 4px;
            border-bottom: 1px dashed var(--border-dark);
        }

        /* ─── COLLEGE HEADER ─────────────────────────── */
        .college-header {
            display: grid;
            grid-template-columns: 70px 1fr 70px;
            gap: 8px;
            align-items: center;
            border: 1px solid var(--border-dark);
            background: linear-gradient(180deg,#fff 0%,#f8fbff 100%);
            padding: 6px 10px;
            border-radius: 8px;
            margin-bottom: 7px;
        }

        .college-logo { width: 70px; height: 70px; object-fit: contain; }

        .college-name-en {
            margin: 0;
            color: var(--primary-dark);
            font-size: 20px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            line-height: 1.2;
        }

        .college-name-hi {
            margin: 3px 0 0;
            color: var(--secondary);
            font-size: 16px;
            font-weight: 700;
        }

        .college-subtitle {
            margin-top: 3px;
            font-size: 11px;
            color: var(--muted);
            font-weight: 600;
        }

        /* ─── TITLE RIBBON ───────────────────────────── */
        .title-ribbon-wrap { text-align: center; margin: 6px 0; }

        .title-ribbon {
            display: inline-block;
            padding: 4px 18px;
            background: linear-gradient(90deg, var(--primary), var(--primary-dark));
            color: #fff;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ─── SUMMARY BAND ───────────────────────────── */
        .summary-band {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 5px;
            margin-bottom: 7px;
        }

        .summary-card {
            border: 1px solid #cbd5e1;
            background: var(--bg-panel);
            border-radius: 6px;
            padding: 4px 8px;
        }

        .summary-card .label {
            font-size: 8.5px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.4px;
            margin-bottom: 2px;
        }

        .summary-card .value {
            font-size: 11px;
            font-weight: 700;
            color: var(--primary-dark);
            word-break: break-word;
        }

        /* ─── SECTION CARD ───────────────────────────── */
        .section-card {
            border: 1px solid #94a3b8;
            border-radius: 7px;
            margin-top: 5px;
            overflow: hidden;
            background: #fff;
        }

        .section-head {
            padding: 4px 10px;
            background: linear-gradient(90deg, rgba(15,76,129,0.07), rgba(139,30,63,0.05));
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
        }

        .section-title {
            margin: 0;
            font-size: 10.5px;
            font-weight: 800;
            color: var(--primary-dark);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .section-subtitle { font-size: 8.5px; color: var(--muted); }

        .section-body { padding: 5px 9px; }

        /* ─── GRIDS ──────────────────────────────────── */
        .grid-main {
            display: grid;
            grid-template-columns: 1fr 108px;
            gap: 10px;
        }

        .grid-2-equal {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        /* ─── INFO ITEMS ─────────────────────────────── */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3px 10px;
        }

        .info-item {
            display: flex;
            align-items: flex-start;
            gap: 4px;
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 2px;
            min-height: 18px;
            font-size: 9px;
        }

        .info-label { width: 46%; color: #4b5563; font-weight: 600; }

        .info-value {
            width: 54%;
            color: #111827;
            font-weight: 700;
            word-break: break-word;
        }

        .info-value::before {
            content: ':';
            margin-right: 5px;
            color: #4b5563;
            font-weight: 500;
        }

        /* ─── PHOTO / SIGN ───────────────────────────── */
        .asset-box {
            width: 108px;
            border: 1px solid var(--border-dark);
            border-radius: 7px;
            background: #fff;
            overflow: hidden;
        }

        .asset-label {
            background: var(--primary);
            color: #fff;
            font-size: 8.5px;
            font-weight: 700;
            text-transform: uppercase;
            text-align: center;
            padding: 3px 4px;
        }

        .asset-image {
            height: 96px;
            display: flex; align-items: center; justify-content: center;
            background: #fff; padding: 4px;
        }

        .asset-sign {
            height: 42px;
            display: flex; align-items: center; justify-content: center;
            background: #fff; padding: 4px;
            border-top: 1px solid var(--border);
        }

        .asset-image img, .asset-sign img {
            max-width: 100%; max-height: 100%; object-fit: contain;
        }

        .placeholder-text { font-size: 8.5px; color: #9ca3af; }

        /* ─── SIDE BADGES ────────────────────────────── */
        .side-info {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3px 8px;
            margin-top: 6px;
        }

        .mini-badge {
            border: 1px solid #cbd5e1;
            background: #fff;
            border-radius: 5px;
            padding: 3px 7px;
        }

        .mini-badge .label { font-size: 8px; color: var(--muted); margin-bottom: 1px; }
        .mini-badge .value { font-size: 10px; font-weight: 700; }

        /* ─── SUBJECT BOX ────────────────────────────── */
        .subject-box {
            border: 1px solid #cbd5e1;
            padding: 5px 8px;
            border-radius: 6px;
            background: #fcfdfe;
            margin-top: 6px;
        }

        .subject-title {
            font-size: 9.5px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            color: var(--primary-dark);
            font-weight: 800;
            margin-bottom: 4px;
        }

        .subject-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 3px 12px;
            font-size: 9px;
        }

        .subject-grid div span { color: var(--muted); font-weight: 600; }

        /* ─── DATA TABLE ─────────────────────────────── */
        table.data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 9px;
        }

        .data-table th, .data-table td {
            border: 1px solid var(--border);
            padding: 4px 6px;
            text-align: left;
            vertical-align: top;
        }

        .data-table thead th {
            background: #eef4fb;
            color: var(--primary-dark);
            font-weight: 800;
            font-size: 8.5px;
            text-transform: uppercase;
        }

        /* ─── WEIGHTAGE ──────────────────────────────── */
        .weightage-list {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 5px 10px;
        }

        .weightage-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 6px;
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 4px 8px;
            background: var(--bg-panel);
            font-size: 9px;
        }

        /* ─── STATUS PILLS ───────────────────────────── */
        .status-pill {
            display: inline-flex; align-items: center; justify-content: center;
            min-width: 40px; padding: 1px 7px;
            border-radius: 999px; font-size: 8.5px; font-weight: 800;
            text-transform: uppercase; letter-spacing: 0.3px; border: 1px solid transparent;
        }

        .status-yes { color: var(--success); background: rgba(31,122,77,0.1); border-color: rgba(31,122,77,0.2); }
        .status-no  { color: #9b1c1c; background: rgba(155,28,28,0.08); border-color: rgba(155,28,28,0.15); }

        /* ─── ADDRESS ────────────────────────────────── */
        .addr-panel {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 7px;
            padding: 6px 9px;
        }

        .addr-title {
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
            color: var(--primary-dark);
            font-weight: 800;
            border-bottom: 2px solid var(--accent);
            display: inline-block;
            padding-bottom: 1px;
            margin-bottom: 5px;
        }

        .addr-info { display: grid; grid-template-columns: 1fr; gap: 3px; }

        /* ─── UNDERTAKING ────────────────────────────── */
        .undertaking-box {
            border: 1px solid var(--border-dark);
            border-radius: 8px;
            padding: 8px 10px;
            background: linear-gradient(180deg,#fffefb 0%,#fff 100%);
            font-size: 9px;
        }

        .undertaking-box ol {
            margin: 5px 0 0;
            padding-left: 15px;
        }

        .undertaking-box li { margin-bottom: 3px; text-align: justify; }

        /* ─── SIGNATURE ROW ──────────────────────────── */
        .signature-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-top: 14px;
            align-items: end;
        }

        .signature-box { text-align: center; }

        .signature-line {
            border-top: 1px solid #111827;
            margin-top: 26px;
            padding-top: 4px;
            font-weight: 700;
            font-size: 9px;
        }

        /* ─── INSTRUCTION GRID ───────────────────────── */
        .instruction-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4px 14px;
            font-size: 9px;
        }

        /* ─── RECEIPT ────────────────────────────────── */
        .receipt-cut {
            border-top: 2px dashed #111827;
            margin: 12px 0;
        }

        .receipt-panel {
            border: 1px solid var(--border-dark);
            border-radius: 8px;
            overflow: hidden;
        }

        .receipt-header {
            background: linear-gradient(90deg, var(--primary), var(--primary-dark));
            color: #fff;
            text-align: center;
            padding: 5px 10px;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.3px;
        }

        .receipt-body {
            padding: 8px 12px;
            background: #fff;
            font-size: 9.5px;
        }

        .receipt-footer {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: 10px;
        }

        .footer-mini-header {
            margin-top: 10px;
            padding-top: 8px;
            border-top: 1px dashed var(--border-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            color: var(--primary-dark);
            font-weight: 700;
            font-size: 9.5px;
        }

        .empty-state { padding: 40px 20px; text-align: center; color: #b91c1c; font-weight: 700; }

        /* ─── PAGE BREAK ─────────────────────────────── */
        .page-break {
            border: none;
            border-top: 3px dashed #94a3b8;
            margin: 10px 0;
            position: relative;
        }

        .page-break::after {
            content: "── Page 2 ──";
            position: absolute;
            left: 50%; top: 50%;
            transform: translate(-50%, -50%);
            background: #fff;
            padding: 0 10px;
            color: var(--muted);
            font-size: 8px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ─── PRINT ──────────────────────────────────── */
        @media print {
            @page { size: A4; margin: 6mm 0; }

            body { margin: 0 !important; padding: 0 !important; background: #fff; font-size: 9px; }

            .no-print, .no-print-toolbar { display: none !important; }

            .application-sheet {
                margin: 0; width: 100%; box-shadow: none;
                border: none;
            }

            .application-sheet::before { display: none; }

            .sheet-inner { padding: 6mm 8mm 7mm; }

            .page-break {
                display: block !important;
                page-break-before: always;
                break-before: page;
                border: none;
                margin: 0;
            }
            .page-break::after { display: none; }

            .section-card, .summary-card, .weightage-item,
            .receipt-panel, .college-header, .addr-panel {
                break-inside: avoid;
                page-break-inside: avoid;
            }
        }

        @media (max-width: 900px) {
            .application-sheet { width: calc(100% - 20px); }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <% if (typeof layout !== 'undefined' && layout === 'frontend') { %>
            <%- include('../../../frontend/layout/header') %>
        <% } else { %>
            <%- include('../../layout/header') %>
        <% } %>
    </div>

    <div class="no-print-toolbar no-print">
        <button onclick="window.print()" class="btn btn-primary btn-sm">
            <i class="bi bi-printer"></i> Print Application
        </button>
        <% if (typeof layout !== 'undefined' && layout === 'student') { %>
            <a href="/student/dashboard" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
        <% } else { %>
            <a href="/print_application_form" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
        <% } %>
    </div>

    <div class="application-sheet">
        <div class="sheet-inner">
            <% if (typeof student !== 'undefined' && student) { %>
                <%
                    let formattedRegDate = '-';
                    if (typeof payment !== 'undefined' && payment) {
                        if (payment.txnCompleteDate) {
                            formattedRegDate = new Date(payment.txnCompleteDate).toLocaleDateString('en-IN');
                        } else if (payment.transaction_date) {
                            formattedRegDate = new Date(payment.transaction_date).toLocaleDateString('en-IN');
                        } else if (payment.created_at) {
                            formattedRegDate = new Date(payment.created_at).toLocaleDateString('en-IN');
                        }
                    } else if (student.createdAt) {
                        formattedRegDate = new Date(student.createdAt).toLocaleDateString('en-IN');
                    }

                    let claimedWeightageIds = [];
                    let studentWeightageObj = student.weightage;
                    if (typeof studentWeightageObj === 'string') {
                        try { studentWeightageObj = JSON.parse(studentWeightageObj); } catch (e) {}
                    }
                    if (studentWeightageObj) {
                        Object.keys(studentWeightageObj).forEach(key => {
                            if (studentWeightageObj[key] === '1' || studentWeightageObj[key] === true) {
                                claimedWeightageIds.push(key.toString());
                            }
                        });
                    }

                    let filteredDocs = [];
                    if (typeof student.documents !== 'undefined' && student.documents.length > 0) {
                        filteredDocs = student.documents.filter(doc => {
                            const code = doc.documentType ? doc.documentType.code : '';
                            return !['photo', 'signature', 'sign'].includes(code);
                        });
                    }

                    let majors = [];
                    if (student.major1 && student.major1.subject_name) majors.push(student.major1.subject_name);
                    if (student.major2 && student.major2.subject_name) majors.push(student.major2.subject_name);
                %>

                <!-- ══════════════════════ PAGE 1 ══════════════════════ -->

                <div class="top-meta">
                    <div>Generated On: <strong><%= new Date().toLocaleString('en-IN') %></strong></div>
                    <div>Institution: <strong><%= fieldLabels.header.college_name_en %></strong></div>
                </div>

                <!-- College Header -->
                <div class="college-header">
                    <div class="text-center">
                        <img src="/uploads/static/logo_header.png" alt="College Logo" class="college-logo">
                    </div>
                    <div class="text-center">
                        <h1 class="college-name-en">Government Women Degree College Robertsganj Sonebhadra</h1>
                        <div class="college-name-hi">राजकीय महिला महाविद्यालय रॉबर्ट्सगंज सोनभद्र</div>
                        <div class="college-subtitle">Affiliated to Mahatma Gandhi Kashi Vidyapeeth, Varanasi</div>
                        <div class="title-ribbon-wrap" style="margin-top:5px;">
                            <div class="title-ribbon">
                                <%= fieldLabels.header.application_title %> | Session: <%= activeAcademicYear ? activeAcademicYear.session : '' %>
                            </div>
                        </div>
                    </div>
                    <div class="text-center">
                        <img src="/uploads/static/logo_header_right.png" alt="College Logo" class="college-logo">
                    </div>
                </div>

                <!-- Summary Band -->
                <div class="summary-band">
                    <div class="summary-card">
                        <div class="label">Registration No.</div>
                        <div class="value"><%= student.registration_no || '-' %></div>
                    </div>
                    <div class="summary-card">
                        <div class="label">Application Date</div>
                        <div class="value"><%= formattedRegDate %></div>
                    </div>
                    <div class="summary-card">
                        <div class="label">Course / Semester</div>
                        <div class="value"><%= student.courseName ? student.courseName.name : '' %> - <%= student.semsterName ? student.semsterName.name : '' %></div>
                    </div>
                    <div class="summary-card">
                        <div class="label">Transaction ID</div>
                        <div class="value"><%= student.user ? student.user.transaction_id : '-' %></div>
                    </div>
                </div>

                <!-- Student Profile -->
                <div class="section-card">
                    <div class="section-head">
                        <h2 class="section-title">Student Profile</h2>
                        <span class="section-subtitle">Primary applicant information</span>
                    </div>
                    <div class="section-body">
                        <div class="grid-main">
                            <!-- Left: Info Grid -->
                            <div>
                                <div class="info-grid">
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.name %></div><div class="info-value"><%= student.user ? student.user.name : '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.dob %></div><div class="info-value"><%= student.dob || '-' %></div></div>
                                    <div class="info-item"><div class="info-label">Contact No.</div><div class="info-value"><%= student.user ? student.user.phone : '-' %></div></div>
                                    <div class="info-item"><div class="info-label">Email Id</div><div class="info-value"><%= student.user ? student.user.email : '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.gender %></div><div class="info-value"><%= student.gender || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.category %></div><div class="info-value"><%= student.category || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.religion %></div><div class="info-value"><%= student.religion || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.caste %></div><div class="info-value"><%= student.caste || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.father_name %></div><div class="info-value"><%= student.father_name || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.mother_name %></div><div class="info-value"><%= student.mother_name || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.local_guardian %></div><div class="info-value"><%= student.local_guadian || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.guardian_contact %></div><div class="info-value"><%= student.guadian_contact || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.local_guardian_address %></div><div class="info-value"><%= student.local_guadian_address || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.family_income %></div><div class="info-value"><%= student.family_annual_income || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.father_occupation %></div><div class="info-value"><%= student.father_occupation || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.mother_occupation %></div><div class="info-value"><%= student.mother_occupation || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.blood_group %></div><div class="info-value"><%= student.blood_group || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.computer_literate %></div><div class="info-value"><%= student.computer_literate || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.adhar_no %></div><div class="info-value"><%= student.adhar_no || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.samarth_no %></div><div class="info-value"><%= student.samarth_no || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.caste_cert_no %></div><div class="info-value"><%= student.cast_certificate_no || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.income_cert_no %></div><div class="info-value"><%= student.income_certificate_no || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.epic_no %></div><div class="info-value"><%= student.epic_no || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.disability %></div><div class="info-value"><%= student.disability_percentage ? 'Yes (' + student.disability_percentage + '%)' : 'No' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.is_18_plus %></div><div class="info-value"><%= student.is_18_plus || 'No' %></div></div>
                                    <% if (student.year_gap === 'Yes') { %>
                                        <div class="info-item"><div class="info-label">Gap Years</div><div class="info-value"><%= student.year_gap_after_inter || '-' %> Years</div></div>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.gap_reason %></div><div class="info-value"><%= student.gap_reason || '-' %></div></div>
                                    <% } else { %>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.year_gap %></div><div class="info-value">No</div></div>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Right: Photo + Sign -->
                            <div>
                                <div class="asset-box">
                                    <div class="asset-label">Photograph</div>
                                    <div class="asset-image">
                                        <% if (student.photo) { %>
                                            <img src="<%= student.photo %>?t=<%= Date.now() %>" alt="Student Photo">
                                        <% } else { %>
                                            <span class="placeholder-text">No Photo</span>
                                        <% } %>
                                    </div>
                                    <div class="asset-label" style="background: #4b5563;">Signature</div>
                                    <div class="asset-sign">
                                        <% if (student.sign) { %>
                                            <img src="<%= student.sign %>?t=<%= Date.now() %>" alt="Student Signature">
                                        <% } else { %>
                                            <span class="placeholder-text">No Signature</span>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Subject Box (Full Width) -->
                        <div class="subject-box">
                            <div class="subject-title">Subject Selection</div>
                            <div class="subject-grid">
                                <% if (student.semsterName && student.semsterName.is_major1_enabled == 1) { %>
                                    <div><span>Major 1:</span> <strong><%= (student.major1 && student.major1.subject_name) ? student.major1.subject_name : 'N/A' %></strong></div>
                                <% } %>
                                
                                <% if (student.semsterName && student.semsterName.is_major2_enabled == 1) { %>
                                    <div><span>Major 2:</span> <strong><%= (student.major2 && student.major2.subject_name) ? student.major2.subject_name : 'N/A' %></strong></div>
                                <% } %>
                                
                                <% if (student.semsterName && student.semsterName.is_minor_enabled == 1) { %>
                                    <div><span>Minor:</span> <strong><%= (student.minor && student.minor.subject_name) ? student.minor.subject_name : 'N/A' %></strong></div>
                                <% } %>
                                
                                <% if (student.semsterName && student.semsterName.is_research_project_enabled == 1) { %>
                                    <div><span>Research Project:</span> <strong><%= (student.researchProject && student.researchProject.subject_name) ? student.researchProject.subject_name : 'N/A' %></strong></div>
                                <% } %>

                                <% if (student.semsterName && (student.semsterName.is_skill_required == 1 || student.semsterName.is_skill_required == '1')) { %>
                                    <div><span>Skill:</span> <strong><%= (student.skill && student.skill.name) ? student.skill.name : 'N/A' %></strong></div>
                                <% } %>

                                <% if (student.semsterName && (student.semsterName.is_cocurricular_required == 1 || student.semsterName.is_cocurricular_required == '1')) { %>
                                    <div><span>Co-Curricular:</span> <strong><%= (student.cocurricular && student.cocurricular.name) ? student.cocurricular.name : 'N/A' %></strong></div>
                                <% } %>
                                
                                <div><span>Prev. Student:</span> <strong><%= student.is_previous_student || 'No' %></strong></div>
                            </div>
                        </div>

                        <!-- Bank Details -->
                        <div class="subject-box" style="margin-top: 8px;">
                            <div class="subject-title">Bank Account Details</div>
                            <div class="subject-grid" style="grid-template-columns: repeat(3, 1fr);">
                                <div><span>Bank Name:</span> <strong><%= student.bank_name || '-' %></strong></div>
                                <div><span>Account No:</span> <strong><%= student.bank_account_no || '-' %></strong></div>
                                <div><span>IFSC Code:</span> <strong><%= student.ifsc_code || '-' %></strong></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Weightage -->
                <div class="section-card" style="margin-top:5px;">
                    <div class="section-head">
                        <h2 class="section-title">Weightage Details</h2>
                        <span class="section-subtitle">Additional merit claims</span>
                    </div>
                    <div class="section-body">
                        <div class="weightage-list">
                            <% if (typeof weightages !== 'undefined' && weightages.length > 0) { %>
                                <% weightages.forEach((w) => { %>
                                    <div class="weightage-item">
                                        <span class="fw-600"><%= w.name %></span>
                                        <% if (claimedWeightageIds.includes(w.id.toString())) { %>
                                            <span class="status-pill status-yes">YES</span>
                                        <% } else { %>
                                            <span class="status-pill status-no">NO</span>
                                        <% } %>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Address Details (Moved to Page 1) -->
                <div class="section-card" style="margin-top:5px;">
                    <div class="section-head">
                        <h2 class="section-title">Address Details</h2>
                        <span class="section-subtitle">Mailing and permanent residence</span>
                    </div>
                    <div class="section-body">
                        <div class="grid-2-equal">
                            <div class="addr-panel">
                                <div class="addr-title">Mailing Address</div>
                                <div class="addr-info">
                                    <div class="info-item"><div class="info-label" style="width:30%">Address</div><div class="info-value" style="width:70%"><%= student.mailing_address || '-' %></div></div>
                                    <div class="info-item"><div class="info-label" style="width:30%">State</div><div class="info-value" style="width:70%"><%= student.mailing_state || '-' %></div></div>
                                    <div class="info-item"><div class="info-label" style="width:30%">District</div><div class="info-value" style="width:70%"><%= student.mailing_district || '-' %></div></div>
                                    <div class="info-item"><div class="info-label" style="width:30%">Tehsil</div><div class="info-value" style="width:70%"><%= student.mailing_tehsil || '-' %></div></div>
                                    <div class="info-item"><div class="info-label" style="width:30%">Pincode</div><div class="info-value" style="width:70%"><%= student.mailing_pincode || '-' %></div></div>
                                </div>
                            </div>
                            <div class="addr-panel">
                                <div class="addr-title">Permanent Address</div>
                                <div class="addr-info">
                                    <div class="info-item"><div class="info-label" style="width:30%">Address</div><div class="info-value" style="width:70%"><%= student.permanent_address || '-' %></div></div>
                                    <div class="info-item"><div class="info-label" style="width:30%">State</div><div class="info-value" style="width:70%"><%= student.permanent_state || '-' %></div></div>
                                    <div class="info-item"><div class="info-label" style="width:30%">District</div><div class="info-value" style="width:70%"><%= student.permanent_district || '-' %></div></div>
                                    <div class="info-item"><div class="info-label" style="width:30%">Tehsil</div><div class="info-value" style="width:70%"><%= student.permanent_tehsil || '-' %></div></div>
                                    <div class="info-item"><div class="info-label" style="width:30%">Pincode</div><div class="info-value" style="width:70%"><%= student.permanent_pincode || '-' %></div></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ══════════════════════ PAGE BREAK ══════════════════════ -->
                <hr class="page-break">

                <!-- Page 2 Header (compact) -->
                <div class="top-meta" style="margin-top:0;">
                    <div><strong><%= student.user ? student.user.name : '-' %></strong> | Reg: <strong><%= student.registration_no || '-' %></strong></div>
                    <div><%= student.courseName ? student.courseName.name : '' %> - <%= student.semsterName ? student.semsterName.name : '' %> | Session: <%= activeAcademicYear ? activeAcademicYear.session : '' %></div>
                </div>

                <!-- Payment Details -->
                <div class="section-card" style="margin-top:5px;">
                    <div class="section-head">
                        <h2 class="section-title">Payment Details</h2>
                        <span class="section-subtitle">Transaction summary</span>
                    </div>
                    <div class="section-body">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Transaction ID</th>
                                    <th>Atom Txn ID</th>
                                    <th>Fee Type</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof payment !== 'undefined' && payment) { %>
                                    <tr>
                                        <td class="fw-600"><%= payment.merchant_txn_id || '-' %></td>
                                        <td><%= payment.atom_txn_id || '-' %></td>
                                        <td>Form Fee</td>
                                        <td class="fw-700">₹ <%= payment.amount || '0.00' %></td>
                                        <td><%= new Date(payment.payment_date || payment.createdAt || Date.now()).toLocaleDateString('en-IN') %></td>
                                        <td><span class="status-pill status-yes"><%= payment.status || 'Success' %></span></td>
                                    </tr>
                                <% } else if (student.user && student.user.transaction_id) { %>
                                    <tr>
                                        <td class="fw-600"><%= student.user.transaction_id %></td>
                                        <td>-</td><td>Form Fee</td><td class="fw-700">-</td><td>-</td>
                                        <td><span class="status-pill status-yes">Success</span></td>
                                    </tr>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" style="text-align:center;" class="muted">Payment details not available</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Academic Qualifications -->
                <div class="section-card" style="margin-top:5px;">
                    <div class="section-head">
                        <h2 class="section-title">Academic Qualifications</h2>
                        <span class="section-subtitle">Educational history and performance</span>
                    </div>
                    <div class="section-body">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Level/Qualification</th>
                                    <th>Board/University</th>
                                    <th>Passing Year</th>
                                    <th>Roll Number</th>
                                    <th>Max Marks</th>
                                    <th>Obt. Marks</th>
                                    <th style="width: 25%;">Subjects</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof educationals !== 'undefined' && educationals.length > 0) { %>
                                    <% educationals.forEach(edu => { %>
                                        <tr>
                                            <td class="fw-600"><%= edu.school_name || (edu.qualification ? edu.qualification.name : edu.class_name) %></td>
                                            <td><%= edu.board_name || '-' %></td>
                                            <td><%= edu.year_of_passing || '-' %></td>
                                            <td class="fw-600"><%= edu.roll_no || '-' %></td>
                                            <td><%= edu.total_marks || '-' %></td>
                                            <td class="fw-700" style="color:var(--primary);"><%= edu.obtained_marks || '-' %></td>
                                            <td style="font-size: 8.5px; line-height: 1.2;"><%= edu.subject_details || '-' %></td>
                                        </tr>
                                    <% }); %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Declaration -->
                <div class="section-card" style="margin-top:5px;">
                    <div class="section-head">
                        <h2 class="section-title">Declaration / Undertaking</h2>
                        <span class="section-subtitle">Applicant self-declaration</span>
                    </div>
                    <div class="section-body">
                        <div class="undertaking-box">
                            <p class="mb-0" style="font-size:9px;">
                                मैं <strong><%= student.user ? student.user.name : '-' %></strong> <%= student.gender === 'Male' ? 'पुत्र' : 'पुत्री/पत्नी' %> <strong><%= student.father_name || '-' %></strong>, कक्षा <strong><%= student.courseName ? student.courseName.name : '' %> - <%= student.semsterName ? student.semsterName.name : '' %></strong> में प्रवेश हेतु यह शपथपूर्वक घोषित <%= student.gender === 'Male' ? 'करता' : 'करती' %> हूँ कि:-
                            </p>
                            <ol>
                                <li>मैं कक्षा में 75% उपस्थिति की अनिवार्यता का पालन करूँगा/करूंगी|</li>
                                <li>प्रवेश के सम्बन्ध में अंतिम निर्णय प्रवेश समिति/प्राचार्य का होगा, जो मुझे स्वीकार्य है|</li>
                                <li>मैं प्राचार्य एवं अनुशासन समिति (नियन्ता मण्डल) द्वारा स्थापित नियमों एवं आदेशों का निष्ठापूर्वक पालन करूँगा/करुँगी|</li>
                                <li>मैं प्राचार्य के अधिकारों को स्वीकार करता/करती हूँ, और यदि मेरा आचरण प्रतिकूल रहा तो उनके द्वारा दी गयी व्यवस्था का प्रतिरोध न करते हुए मैं उसे अंतिम निर्णय के रूप में स्वीकार करूँगा/करुँगी|</li>
                                <li>मैं घोषणा करता/करती हूँ कि सभी प्रविष्टियाँ सही हैं| दी गई सूचनाओं के लिए मै स्वयं पूर्णत: जिम्मेदार हूँ |</li>
                                <li>मैं सभी विषय की कक्षाओं में नियमित रूप से उपस्थित रहूँगा/रहूँगी| मेरा यह भी उत्तरदायित्व होगा कि अपेक्षित उपस्थिति सम्बंधित सूचना सम्बंधित प्राध्यापक से प्राप्त कर लूँ|</li>
                            </ol>
                            <div class="signature-row">
                                <div class="signature-box">
                                    <div class="signature-line">Guardian's Signature</div>
                                </div>
                                <div class="signature-box">
                                    <div style="height: 40px; display: flex; align-items: center; justify-content: center; margin-bottom: 4px;">
                                        <% if (student.sign) { %>
                                            <img src="<%= student.sign %>" alt="Applicant Signature" style="max-height: 100%; max-width: 150px; object-fit: contain;">
                                        <% } %>
                                    </div>
                                    <div class="signature-line" style="margin-top:0;">Applicant's Signature</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="receipt-cut"></div>

                <div class="receipt-panel">
                    <div class="receipt-header">STUDENT ADMISSION SLIP (COLLEGE COPY) - SESSION <%= activeAcademicYear ? activeAcademicYear.session : '-' %></div>
                    <div class="receipt-body">
                        <div class="grid-2-equal">
                            <div class="info-grid" style="grid-template-columns: 1fr;">
                                <div class="info-item"><div class="info-label">Student Name</div><div class="info-value"><%= student.user ? student.user.name : '-' %></div></div>
                                <div class="info-item"><div class="info-label">Father's Name</div><div class="info-value"><%= student.father_name || '-' %></div></div>
                                <div class="info-item"><div class="info-label">Registration No</div><div class="info-value"><%= student.registration_no || '-' %></div></div>
                            </div>
                            <div class="info-grid" style="grid-template-columns: 1fr;">
                                <div class="info-item"><div class="info-label">Course Name</div><div class="info-value"><%= student.courseName ? student.courseName.name : '-' %></div></div>
                                <div class="info-item"><div class="info-label">Semester</div><div class="info-value"><%= student.semsterName ? student.semsterName.name : '-' %></div></div>
                                <div class="info-item"><div class="info-label">Category</div><div class="info-value"><%= student.category || '-' %></div></div>
                            </div>
                        </div>

                        <div class="footer-mini-header">
                            <img src="/uploads/static/logo_header.png" style="height: 18px">
                            Government Women Degree College Robertsganj Sonebhadra
                        </div>

                        <div class="receipt-footer">
                            <div class="small muted">Date: <%= new Date().toLocaleDateString('en-IN') %></div>
                            <div class="text-right">
                                <div style="height: 40px;"></div>
                                <div class="fw-700" style="border-top: 1px solid #000; display: inline-block; padding-top: 2px;">Admission In-charge Signature</div>
                            </div>
                        </div>
                    </div>
                </div>
            <% } else { %>
                <div class="empty-state">Applicant data session expired. Please search again.</div>
            <% } %>
        </div>
    </div>

    <div class="no-print">
        <% if (typeof layout !== 'undefined' && layout === 'frontend') { %>
            <%- include('../../../frontend/layout/footer') %>
        <% } else { %>
            <%- include('../../layout/footer') %>
        <% } %>
    </div>
    <% if (typeof layout !== 'undefined' && layout === 'frontend') { %>
        <%- include('../../../frontend/layout/script_link') %>
    <% } else { %>
        <%- include('../../layout/script_link') %>
    <% } %>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Payment' %></title>
    <style>
        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background-color: #f5f5f5;
        }
        .payment-container {
            text-align: center;
            padding: 20px;
        }
        .spinner {
            border: 4px solid #f3f3f3;
            border-top: 4px solid #3498db;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            animation: spin 1s linear infinite;
            margin: 20px auto;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .message {
            color: #333;
            font-size: 18px;
            margin-top: 20px;
        }
    </style>
</head>

<body>
    <div class="payment-container">
        <div class="spinner"></div>
        <div class="message">Redirecting to payment gateway...</div>
    </div>

    <% if (typeof atomTokenId !== 'undefined' && atomTokenId) { %>
        <!-- Atom Paynetz AIPAY requires POST form submission -->
        <form id="atomPaymentForm" method="POST" action="<%= typeof data !== 'undefined' && data.paymentPageUrl ? data.paymentPageUrl : 'https://paynetzuat.atomtech.in/ots/aipay/payment' %>" style="display: none;">
            <!-- Required fields for Atom Paynetz AIPAY -->
            <input type="hidden" name="atomTokenId" value="<%= atomTokenId %>">
            <input type="hidden" name="merchId" value="<%= typeof data !== 'undefined' && data.login ? data.login : '445842' %>">
        </form>
        <script>
            (function() {
                var form = document.getElementById('atomPaymentForm');
                var tokenId = "<%= atomTokenId %>";
                var merchantId = "<%= typeof data !== 'undefined' && data.login ? data.login : '445842' %>";
                var paymentUrl = "<%= typeof data !== 'undefined' && data.paymentPageUrl ? data.paymentPageUrl : 'https://paynetzuat.atomtech.in/ots/aipay/payment' %>";

                console.log('=== PAYMENT REDIRECT DEBUG ===');
                console.log('Full form HTML:', form ? form.outerHTML : 'FORM NOT FOUND');

                if (form && tokenId) {
                    console.log('=== PAYMENT FORM SUBMISSION (POST) ===');
                    console.log('Token ID:', tokenId);
                    console.log('Merchant ID:', merchantId);
                    console.log('Payment URL:', paymentUrl);
                    console.log('Form method:', form.method);

                    var formData = new FormData(form);
                    for (var pair of formData.entries()) {
                        console.log(pair[0] + ': ' + pair[1]);
                    }

                    form.submit();
                } else {
                    console.error('Payment form error', { form, tokenId });
                    alert('Payment token generation failed. Please try again.');
                    window.location.href = '/registration_fees_payment';
                }
            })();
        </script>

    <% } else { %>
        <script>
            alert('Payment token generation failed. Please try again.');
            window.location.href = '/registration_fees_payment';
        </script>
    <% } %>
</body>
</html>


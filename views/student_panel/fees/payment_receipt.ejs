<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layout/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Payment Receipt' %></title>
    <style>
        @media print {
            .no-print { display: none; }
        }
    </style>
</head>
<body>
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-body">
                        <div class="row align-items-center mb-4 border-bottom pb-3">
                            <div class="col-2 text-start">
                                <img src="/uploads/static/logo_header.png" alt="Logo Left" style="max-height: 60px;">
                            </div>
                            <div class="col-8 text-center" style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; overflow: hidden;">
                                <h5 class="fw-bold mb-1" style="color: #b71c1c; font-size: 15px; white-space: nowrap;">Government Women Degree College Robertsganj Sonebhadra</h5>
                                <div class="hindi-title fw-bold mb-1" style="color: #1565c0; font-size: 13px; white-space: nowrap;">राजकीय महिला महाविद्यालय रॉबर्ट्सगंज सोनभद्र</div>
                                <div class="affiliation small text-primary" style="font-size: 10px; white-space: nowrap;">Affiliated to Mahatma Gandhi Kashi Vidyapeeth, Varanasi</div>
                                <div class="mt-2 fw-bold text-dark" style="text-decoration: underline;">ADMISSION FEE RECEIPT</div>
                            </div>
                            <div class="col-2 text-end">
                                <img src="/uploads/static/logo_header_right.png" alt="Logo Right" style="max-height: 60px;">
                            </div>
                        </div>

                        <% if (typeof payment !== 'undefined' && payment) { %>
                            <table class="table table-bordered">
                                <tr>
                                    <th><%= fieldLabels.receipt.fields.txn_id %>:</th>
                                    <td><%= payment.transaction_id || '-' %></td>
                                </tr>
                                <tr>
                                    <th><%= fieldLabels.receipt.fields.reg_no %>:</th>
                                    <td><%= payment.registration_no || '-' %></td>
                                </tr>
                                <tr>
                                    <th><%= fieldLabels.receipt.fields.name %>:</th>
                                    <td><%= payment.student_name || '-' %></td>
                                </tr>
                                <tr>
                                    <th><%= fieldLabels.receipt.fields.amount %>:</th>
                                    <td>₹<%= payment.amount || '0' %></td>
                                </tr>
                                <tr>
                                    <th><%= fieldLabels.receipt.fields.txn_date %>:</th>
                                    <td><%= payment.payment_date || '-' %></td>
                                </tr>
                                <tr>
                                    <th><%= fieldLabels.receipt.fields.status %>:</th>
                                    <td>
                                        <% if (payment.status == 'Success') { %>
                                            <span class="badge bg-success">Success</span>
                                        <% } else { %>
                                            <span class="badge bg-danger"><%= payment.status %></span>
                                        <% } %>
                                    </td>
                                </tr>
                            </table>
                        <% } else { %>
                            <div class="alert alert-warning">Payment details not found.</div>
                        <% } %>

                        <div class="text-center mt-4 no-print">
                            <button onclick="window.print()" class="btn btn-primary me-2">Print Receipt</button>
                            <a href="/student/dashboard" class="btn btn-secondary">Go to Dashboard</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>


<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= typeof title !== 'undefined' ? title : 'Student Panel' %> || राजकीय महिला महाविद्यालय रॉबर्ट्सगंज सोनभद्र</title>
    <%- include('css_link') %>
</head>
<body>
    <%- include('header') %>
    <%- typeof body !== 'undefined' ? body : '' %>

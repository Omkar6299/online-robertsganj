<!DOCTYPE html>
<html lang="en">
<head>
<% if (typeof layout !== 'undefined' && layout === 'frontend') { %>
        <%- include('../../../frontend/layout/css_link') %>
    <% } else { %>
        <%- include('../../layout/css_link') %>
    <% } %>
    <title><%= typeof title !== 'undefined' ? title : 'Application Form Preview' %></title>
    <style>
        :root {
            --primary: #0f4c81;
            --primary-dark: #0a3559;
            --secondary: #8b1e3f;
            --accent: #c8a96a;
            --border: #cfd8e3;
            --border-dark: #9fb2c8;
            --text: #1f2937;
            --muted: #6b7280;
            --bg-soft: #f5f7fb;
            --bg-panel: #f9fbfd;
            --white: #ffffff;
            --success: #1f7a4d;
        }

        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
            color: var(--text);
            background: #eef2f7;
            line-height: 1.4;
        }

        .no-print-toolbar {
            text-align: center;
            padding: 18px 12px;
        }

        .application-sheet {
            width: 210mm;
            min-height: 297mm;
            margin: 14px auto;
            background: var(--white);
            box-shadow: 0 14px 35px rgba(15, 76, 129, 0.12);
            border: 1px solid #94a3b8;
            position: relative;
            overflow: hidden;
            font-size: 11px;
        }

        .application-sheet::before {
            content: "";
            position: absolute;
            inset: 0 0 auto 0;
            height: 10px;
            background: linear-gradient(90deg, var(--primary-dark), var(--primary), var(--secondary));
        }

        .sheet-inner {
            padding: 10mm 10mm 10mm;
        }

        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .fw-700 { font-weight: 700; }
        .fw-600 { font-weight: 600; }
        .small { font-size: 10px; }
        .muted { color: var(--muted); }
        .mb-0 { margin-bottom: 0; }
        .mt-0 { margin-top: 0; }
        .mt-8 { margin-top: 8px; }
        .mt-12 { margin-top: 12px; }
        .mt-16 { margin-top: 16px; }
        .mt-20 { margin-top: 20px; }
        .mt-24 { margin-top: 24px; }

        .top-meta {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            align-items: center;
            font-size: 10px;
            color: var(--muted);
            margin-bottom: 10px;
            padding-bottom: 6px;
            border-bottom: 1px dashed var(--border-dark);
        }

        .college-header {
            border: 1px solid var(--border-dark);
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            padding: 8px 12px;
            border-radius: 10px;
            margin-bottom: 12px;
        }

        .college-header-grid {
            display: grid;
            grid-template-columns: 70px 1fr 70px;
            gap: 12px;
            align-items: center;
        }

        .college-logo {
            width: 70px;
            height: 70px;
            object-fit: contain;
        }

        .college-name-en {
            margin: 0;
            color: var(--primary-dark);
            font-size: 20px;
            line-height: 1.2;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .college-name-hi {
            margin: 4px 0 0;
            color: var(--secondary);
            font-size: 16px;
            line-height: 1.25;
            font-weight: 700;
        }

        .college-subtitle {
            margin-top: 6px;
            font-size: 11px;
            color: var(--muted);
            font-weight: 600;
        }

        .title-ribbon-wrap {
            text-align: center;
            margin-top: 12px;
        }

        .title-ribbon {
            display: inline-block;
            padding: 7px 20px;
            background: linear-gradient(90deg, var(--primary), var(--primary-dark));
            color: #fff;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            box-shadow: 0 6px 14px rgba(15, 76, 129, 0.18);
        }

        .summary-band {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            margin: 10px 0 12px;
        }

        .summary-card {
            border: 1px solid #cbd5e1;
            background: var(--bg-panel);
            border-radius: 8px;
            padding: 5px 10px;
            min-height: 52px;
        }

        .summary-card .label {
            font-size: 10px;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }

        .summary-card .value {
            font-size: 13px;
            font-weight: 700;
            color: var(--primary-dark);
            word-break: break-word;
        }

        .section-card {
            border: 1px solid #94a3b8;
            border-radius: 10px;
            margin-top: 10px;
            overflow: hidden;
            background: #fff;
        }

        .section-head {
            padding: 6px 14px;
            background: linear-gradient(90deg, rgba(15, 76, 129, 0.08), rgba(139, 30, 63, 0.06));
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
        }

        .section-title {
            margin: 0;
            font-size: 13px;
            font-weight: 800;
            color: var(--primary-dark);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .section-subtitle {
            font-size: 10px;
            color: var(--muted);
        }

        .section-body {
            padding: 8px 14px;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 16px;
        }

        .grid-2-equal {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px 16px;
        }

        .info-item {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            border-bottom: 1px solid #f1f5f9;
            padding-bottom: 4px;
            min-height: 25px;
        }

        .info-label {
            width: 44%;
            color: #4b5563;
            font-weight: 600;
        }

        .info-value {
            width: 56%;
            color: #111827;
            font-weight: 700;
            word-break: break-word;
        }

        .info-value::before {
            content: ':';
            margin-right: 8px;
            color: #4b5563;
            font-weight: 500;
        }

        .profile-panel {
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px;
            background: var(--bg-soft);
            height: 100%;
        }

        .photo-sign-stack {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-bottom: 14px;
        }

        .asset-box {
            width: 120px;
            border: 1px solid var(--border-dark);
            border-radius: 10px;
            background: #fff;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(15, 76, 129, 0.05);
        }

        .asset-label {
            background: var(--primary);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            text-transform: uppercase;
            text-align: center;
            padding: 5px 4px;
            letter-spacing: 0.4px;
        }

        .asset-image {
            height: 118px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            padding: 6px;
        }

        .asset-sign {
            height: 54px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            padding: 6px;
            border-top: 1px solid var(--border);
        }

        .asset-image img,
        .asset-sign img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

        .placeholder-text {
            font-size: 10px;
            color: #9ca3af;
        }

        .badge-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 10px;
        }

        .mini-badge {
            border: 1px solid #cbd5e1;
            background: #fff;
            border-radius: 8px;
            padding: 5px 10px;
        }

        .mini-badge .label {
            font-size: 10px;
            color: var(--muted);
            margin-bottom: 3px;
        }

        .mini-badge .value {
            font-size: 12px;
            font-weight: 700;
        }

        .subject-box {
            border: 1px solid #cbd5e1;
            padding: 8px 10px;
            border-radius: 8px;
            background: #fcfdfe;
            margin-top: 12px;
        }

        .subject-title {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            color: var(--primary-dark);
            font-weight: 800;
            margin-bottom: 8px;
        }

        .subject-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px 16px;
            font-size: 11px;
        }

        .subject-grid div span {
            color: var(--muted);
            font-weight: 600;
        }

        table.data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }

        .data-table th,
        .data-table td {
            border: 1px solid var(--border);
            padding: 7px 8px;
            text-align: left;
            vertical-align: top;
        }

        .data-table thead th {
            background: #eef4fb;
            color: var(--primary-dark);
            font-weight: 800;
            font-size: 10.5px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .weightage-list {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px 16px;
        }

        .weightage-item {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 8px 10px;
            background: var(--bg-panel);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 54px;
            padding: 2px 10px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            border: 1px solid transparent;
        }

        .status-yes {
            color: var(--success);
            background: rgba(31, 122, 77, 0.1);
            border-color: rgba(31, 122, 77, 0.2);
        }

        .status-no {
            color: #9b1c1c;
            background: rgba(155, 28, 28, 0.08);
            border-color: rgba(155, 28, 28, 0.15);
        }

        .documents-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px 14px;
        }

        .document-chip {
            border: 1px solid var(--border);
            border-left: 4px solid var(--accent);
            border-radius: 10px;
            padding: 8px 10px;
            background: #fff;
            font-weight: 600;
            color: #374151;
        }

        .undertaking-box {
            border: 1px solid var(--border-dark);
            border-radius: 14px;
            padding: 14px;
            background: linear-gradient(180deg, #fffefb 0%, #ffffff 100%);
        }

        .undertaking-box ol {
            margin: 8px 0 0;
            padding-left: 18px;
        }

        .undertaking-box li {
            margin-bottom: 6px;
            text-align: justify;
        }

        .highlight-box {
            margin-top: 14px;
            border: 1px solid rgba(139, 30, 63, 0.2);
            background: rgba(139, 30, 63, 0.04);
            border-radius: 12px;
            padding: 12px;
        }

        .signature-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-top: 24px;
            align-items: end;
        }

        .signature-box {
            text-align: center;
        }

        .signature-line {
            border-top: 1px solid #111827;
            margin-top: 36px;
            padding-top: 5px;
            font-weight: 700;
        }

        .instruction-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px 18px;
            font-size: 11px;
        }

        .receipt-cut {
            border-top: 2px dashed #111827;
            margin: 24px 0;
        }

        .receipt-panel {
            border: 1px solid var(--border-dark);
            border-radius: 14px;
            overflow: hidden;
        }

        .receipt-header {
            background: linear-gradient(90deg, var(--primary), var(--primary-dark));
            color: #fff;
            text-align: center;
            padding: 8px 10px;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.4px;
        }

        .receipt-body {
            padding: 14px;
            background: #fff;
        }

        .receipt-footer {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-top: 18px;
            align-items: end;
        }

        .footer-mini-header {
            margin-top: 16px;
            padding-top: 12px;
            border-top: 1px dashed var(--border-dark);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            color: var(--primary-dark);
            font-weight: 700;
        }

        .empty-state {
            padding: 50px 20px;
            text-align: center;
            color: #b91c1c;
            font-weight: 700;
        }

        @media print {
            @page {
                size: A4;
                margin: 8mm 0;
            }
            body {
                margin: 0 !important;
                padding: 0 !important;
                background: #fff;
            }

            .no-print,
            .no-print-toolbar {
                display: none !important;
            }

            .application-sheet {
                margin: 0;
                width: 100%;
                min-height: auto;
                box-shadow: none;
                border: 1px solid #000;
                border-radius: 0;
            }

            .application-sheet::before { display: none; }

            .sheet-inner {
                padding: 8mm 10mm 10mm;
            }

            .section-card {
                margin-top: 8px;
                border-radius: 8px;
                break-inside: avoid;
                page-break-inside: avoid;
            }

            .section-head {
                padding: 6px 10px;
            }

            .section-body {
                padding: 8px 10px;
            }

            .summary-band {
                margin: 10px 0 10px;
                gap: 6px;
            }

            .subject-box,
            .receipt-panel,
            .summary-card {
                break-inside: avoid;
                page-break-inside: avoid;
            }

            .section-card,
            .undertaking-box,
            .receipt-panel,
            .college-header,
            .summary-card,
            .profile-panel,
            .weightage-item,
            .document-chip {
                break-inside: avoid;
                page-break-inside: avoid;
            }
        }

        @media (max-width: 900px) {
            .application-sheet {
                width: calc(100% - 20px);
            }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <% if (typeof layout !== 'undefined' && layout === 'frontend') { %>
            <%- include('../../../frontend/layout/header') %>
        <% } else if (typeof layout !== 'undefined' && layout === 'student') { %>
            <%- include('../../../student_panel/layout/header') %>
        <% } %>
    </div>

    <div class="no-print-toolbar no-print">
        <button onclick="window.print()" class="btn btn-primary btn-sm">
            <i class="bi bi-printer"></i> Print Application
        </button>
        <% if (typeof layout !== 'undefined' && layout === 'student') { %>
            <a href="/student/dashboard" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
        <% } else { %>
            <a href="/print_application_form" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
        <% } %>
    </div>

    <div class="application-sheet">
        <div class="sheet-inner">
            <% if (typeof student !== 'undefined' && student) { %>
                <%
                    let formattedRegDate = '-';
                    if (typeof payment !== 'undefined' && payment) {
                        if (payment.txnCompleteDate) {
                            formattedRegDate = new Date(payment.txnCompleteDate).toLocaleDateString('en-IN');
                        } else if (payment.transaction_date) {
                            formattedRegDate = new Date(payment.transaction_date).toLocaleDateString('en-IN');
                        } else if (payment.created_at) {
                            formattedRegDate = new Date(payment.created_at).toLocaleDateString('en-IN');
                        }
                    } else if (student.createdAt) {
                        formattedRegDate = new Date(student.createdAt).toLocaleDateString('en-IN');
                    }

                    let claimedWeightageIds = [];
                    let studentWeightageObj = student.weightage;
                    if (typeof studentWeightageObj === 'string') {
                        try { studentWeightageObj = JSON.parse(studentWeightageObj); } catch (e) {}
                    }
                    if (studentWeightageObj) {
                        Object.keys(studentWeightageObj).forEach(key => {
                            if (studentWeightageObj[key] === '1' || studentWeightageObj[key] === true) {
                                claimedWeightageIds.push(key.toString());
                            }
                        });
                    }

                    let filteredDocs = [];
                    if (typeof student.documents !== 'undefined' && student.documents.length > 0) {
                        filteredDocs = student.documents.filter(doc => {
                            const code = doc.documentType ? doc.documentType.code : '';
                            return !['photo', 'signature', 'sign'].includes(code);
                        });
                    }

                    let majors = [];
                    if (student.major1 && student.major1.subject_name) majors.push(student.major1.subject_name);
                    if (student.major2 && student.major2.subject_name) majors.push(student.major2.subject_name);
                %>

                <div class="top-meta">
                    <div>Generated On: <strong><%= new Date().toLocaleString('en-IN') %></strong></div>
                    <div>Institution: <strong><%= fieldLabels.header.college_name_en %></strong></div>
                </div>

                <div class="college-header">
                    <div class="college-header-grid">
                        <div class="text-center">
                            <img src="/uploads/static/logo_header.png" alt="College Logo" class="college-logo">
                        </div>
                        <div class="text-center">
                            <h1 class="college-name-en">Government Women Degree College Robertsganj Sonebhadra</h1>
                            <div class="college-name-hi">राजकीय महिला महाविद्यालय रॉबर्ट्सगंज सोनभद्र</div>
                            <div class="college-subtitle">Affiliated to Mahatma Gandhi Kashi Vidyapeeth, Varanasi</div>
                        </div>
                        <div class="text-center">
                            <img src="/uploads/static/logo_header_right.png" alt="College Logo" class="college-logo">
                        </div>
                    </div>
                    <div class="title-ribbon-wrap">
                        <div class="title-ribbon">
                            <%= fieldLabels.header.application_title %> | Session: <%= activeAcademicYear ? activeAcademicYear.session : '' %>
                        </div>
                    </div>
                </div>

                <div class="summary-band">
                    <div class="summary-card">
                        <div class="label">Registration No.</div>
                        <div class="value"><%= student.registration_no || '-' %></div>
                    </div>
                    <div class="summary-card">
                        <div class="label">Application Date</div>
                        <div class="value"><%= formattedRegDate %></div>
                    </div>
                    <div class="summary-card">
                        <div class="label">Course / Semester</div>
                        <div class="value"><%= student.courseName ? student.courseName.name : '-' %> - <%= student.semsterName ? student.semsterName.name : '-' %></div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Student Profile</h3>
                        <div class="section-subtitle">Primary applicant information</div>
                    </div>
                    <div class="section-body">
                        <div class="grid-2">
                            <div>
                                <div class="info-grid">
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.name %></div><div class="info-value"><%= student.user ? student.user.name : '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.dob %></div><div class="info-value"><%= student.dob || '-' %></div></div>
                                    <div class="info-item"><div class="info-label">Contact No.</div><div class="info-value"><%= student.user ? student.user.phone : '-' %></div></div>
                                    <div class="info-item"><div class="info-label">Email Id</div><div class="info-value"><%= student.user ? student.user.email : '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.gender %></div><div class="info-value"><%= student.gender || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.category %></div><div class="info-value"><%= student.category || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.religion %></div><div class="info-value"><%= student.religion || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.father_name %></div><div class="info-value"><%= student.father_name || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.mother_name %></div><div class="info-value"><%= student.mother_name || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.local_guardian %></div><div class="info-value"><%= student.local_guadian || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.guardian_contact %></div><div class="info-value"><%= student.guadian_contact || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.family_income %></div><div class="info-value"><%= student.family_annual_income || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.computer_literate %></div><div class="info-value"><%= student.computer_literate || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.adhar_no %></div><div class="info-value"><%= student.adhar_no || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.samarth_no %></div><div class="info-value"><%= student.samarth_no || '-' %></div></div>
                                    <% if (student.year_gap === 'Yes') { %>
                                        <div class="info-item"><div class="info-label">Gap Years</div><div class="info-value"><%= student.year_gap_after_inter || '-' %> Years</div></div>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.gap_reason %></div><div class="info-value"><%= student.gap_reason || '-' %></div></div>
                                    <% } else { %>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.year_gap %></div><div class="info-value">No</div></div>
                                    <% } %>
                                </div>

                                <div class="subject-box">
                                    <div class="subject-title">Subject Selection</div>
                                    <div class="subject-grid">
                                        <div><span>Major Subject 1:</span> <strong><%= majors[0] || 'N/A' %></strong></div>
                                        <div><span>Major Subject 2:</span> <strong><%= majors[1] || 'N/A' %></strong></div>
                                        <div><span>Minor Subject:</span> <strong><%= student.minor && student.minor.subject_name ? student.minor.subject_name : 'N/A' %></strong></div>
                                        <div><span>Skill Development:</span> <strong><%= student.skill && student.skill.name ? student.skill.name : 'N/A' %></strong></div>
                                        <div><span>Co-Curricular:</span> <strong><%= student.cocurricular && student.cocurricular.name ? student.cocurricular.name : 'N/A' %></strong></div>
                                        <div><span>Previous Student:</span> <strong><%= student.is_previous_student || 'No' %></strong></div>
                                    </div>
                                </div>
                                <div class="subject-box" style="margin-top: 8px;">
                                    <div class="subject-title">Bank Account Details</div>
                                    <div class="info-grid" style="grid-template-columns: repeat(3, 1fr); gap: 10px;">
                                        <div class="info-item">
                                            <div class="info-label"><%= fieldLabels.application.fields.bank_name %></div>
                                            <div class="info-value"><%= student.bank_name || '-' %></div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label"><%= fieldLabels.application.fields.bank_account_no %></div>
                                            <div class="info-value"><%= student.bank_account_no || '-' %></div>
                                        </div>
                                        <div class="info-item">
                                            <div class="info-label"><%= fieldLabels.application.fields.ifsc_code %></div>
                                            <div class="info-value"><%= student.ifsc_code || '-' %></div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <div class="profile-panel">
                                    <div class="photo-sign-stack">
                                        <div class="asset-box">
                                            <div class="asset-label">Photograph</div>
                                            <div class="asset-image">
                                                <% if (student.photo) { %>
                                                    <img src="<%= student.photo %>?t=<%= Date.now() %>" alt="Student Photo">
                                                <% } else { %>
                                                    <span class="placeholder-text">No Photo</span>
                                                <% } %>
                                            </div>
                                            <div class="asset-sign">
                                                <% if (student.sign) { %>
                                                    <img src="<%= student.sign %>?t=<%= Date.now() %>" alt="Student Signature">
                                                <% } else { %>
                                                    <span class="placeholder-text">No Signature</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="info-grid" style="grid-template-columns: 1fr; gap: 8px;">
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.caste_cert_no %></div><div class="info-value"><%= student.cast_certificate_no || '-' %></div></div>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.caste %></div><div class="info-value"><%= student.caste || '-' %></div></div>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.blood_group %></div><div class="info-value"><%= student.blood_group || '-' %></div></div>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.father_occupation %></div><div class="info-value"><%= student.father_occupation || '-' %></div></div>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.mother_occupation %></div><div class="info-value"><%= student.mother_occupation || '-' %></div></div>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.local_guardian_address %></div><div class="info-value"><%= student.local_guadian_address || '-' %></div></div>
                                        <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.income_cert_no %></div><div class="info-value"><%= student.income_certificate_no || '-' %></div></div>
                                    </div>

                                    <div class="badge-row">
                                        <div class="mini-badge">
                                            <div class="label"><%= fieldLabels.application.fields.disability %></div>
                                            <div class="value"><%= student.disability_percentage ? 'Yes' : 'No' %></div>
                                        </div>
                                        <div class="mini-badge">
                                            <div class="label"><%= fieldLabels.application.fields.disability_percentage_label %></div>
                                            <div class="value"><%= student.disability_percentage || '-' %></div>
                                        </div>
                                        <div class="mini-badge">
                                            <div class="label"><%= fieldLabels.application.fields.is_18_plus %></div>
                                            <div class="value"><%= student.is_18_plus || 'No' %></div>
                                        </div>
                                        <div class="mini-badge">
                                            <div class="label"><%= fieldLabels.application.fields.epic_no %></div>
                                            <div class="value"><%= student.epic_no || '-' %></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Address Details</h3>
                        <div class="section-subtitle">Mailing and permanent residence information</div>
                    </div>
                    <div class="section-body">
                        <div class="grid-2-equal">
                            <div>
                                <div class="subject-title">Mailing Address</div>
                                <div class="info-grid" style="grid-template-columns: 1fr;">
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.mailing_address %></div><div class="info-value"><%= student.mailing_address || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.state %></div><div class="info-value"><%= student.mailing_state || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.district %></div><div class="info-value"><%= student.mailing_district || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.tehsil %></div><div class="info-value"><%= student.mailing_tehsil || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.pincode %></div><div class="info-value"><%= student.mailing_pincode || '-' %></div></div>
                                </div>
                            </div>
                            <div>
                                <div class="subject-title">Permanent Address</div>
                                <div class="info-grid" style="grid-template-columns: 1fr;">
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.permanent_address %></div><div class="info-value"><%= student.permanent_address || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.state %></div><div class="info-value"><%= student.permanent_state || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.district %></div><div class="info-value"><%= student.permanent_district || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.tehsil %></div><div class="info-value"><%= student.permanent_tehsil || '-' %></div></div>
                                    <div class="info-item"><div class="info-label"><%= fieldLabels.application.fields.pincode %></div><div class="info-value"><%= student.permanent_pincode || '-' %></div></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Payment Details</h3>
                        <div class="section-subtitle">Fee transaction summary</div>
                    </div>
                    <div class="section-body">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th><%= fieldLabels.receipt.fields.atom_txn_id %></th>
                                    <th><%= fieldLabels.receipt.fields.merchant_txn_id %></th>
                                    <th><%= fieldLabels.receipt.fields.txn_date %></th>
                                    <th><%= fieldLabels.receipt.fields.amount %></th>
                                    <th><%= fieldLabels.receipt.fields.status %></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof payment !== 'undefined' && payment && payment.merchant_txn_id) { %>
                                    <tr>
                                        <td><%= payment.atom_txn_id || '-' %></td>
                                        <td><%= payment.merchant_txn_id %></td>
                                        <td><%= (payment.transaction_date || payment.createdAt || payment.created_at) ? new Date(payment.transaction_date || payment.createdAt || payment.created_at).toLocaleString('en-IN') : '-' %></td>
                                        <td>₹ <%= payment.amount %></td>
                                        <td><%= payment.status || '-' %></td>
                                    </tr>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center">No payment details found</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Academic Qualifications</h3>
                        <div class="section-subtitle">Education history submitted by applicant</div>
                    </div>
                    <div class="section-body">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th><%= fieldLabels.academic.course %></th>
                                    <th><%= fieldLabels.academic.board %></th>
                                    <th><%= fieldLabels.academic.year %></th>
                                    <th><%= fieldLabels.academic.roll_no %></th>
                                    <th><%= fieldLabels.academic.max_marks %></th>
                                    <th><%= fieldLabels.academic.obt_marks %></th>
                                    <th><%= fieldLabels.academic.place %></th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof educationals !== 'undefined' && educationals.length > 0) { %>
                                    <% educationals.forEach(edu => { %>
                                        <%
                                            let instName = edu.school_name || '-';
                                            if (instName === '0') instName = '-';
                                        %>
                                        <tr>
                                            <td class="fw-600"><%= instName %></td>
                                            <td><%= edu.board_name || '-' %></td>
                                            <td><%= edu.year_of_passing || '-' %></td>
                                            <td><%= edu.roll_no || '-' %></td>
                                            <td><%= edu.total_marks || '-' %></td>
                                            <td><%= edu.obtained_marks || '-' %></td>
                                            <td>Any other</td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="text-center">No academic details found</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Weightage Information</h3>
                        <div class="section-subtitle">Claimed benefits and eligibility details</div>
                    </div>
                    <div class="section-body">
                        <% if (typeof weightages !== 'undefined' && weightages.length > 0) { %>
                            <div class="weightage-list">
                                <% weightages.forEach((w, index) => { %>
                                    <div class="weightage-item">
                                        <div><strong><%= index + 1 %>.</strong> <%= w.name %></div>
                                        <div>
                                            <% const isClaimed = claimedWeightageIds.includes(w.id.toString()); %>
                                            <span class="status-pill <%= isClaimed ? 'status-yes' : 'status-no' %>"><%= isClaimed ? 'Yes' : 'No' %></span>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="text-center muted">No weightage options available</div>
                        <% } %>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Uploaded Documents</h3>
                        <div class="section-subtitle">Supporting documents submitted with the application</div>
                    </div>
                    <div class="section-body">
                        <% if (filteredDocs.length > 0) { %>
                            <div class="documents-grid">
                                <% filteredDocs.forEach((doc, idx) => { %>
                                    <div class="document-chip"><%= idx + 1 %>. <%= doc.documentType ? doc.documentType.name : 'Unknown Document' %></div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="text-center muted">No additional documents uploaded</div>
                        <% } %>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Declaration / Undertaking</h3>
                        <div class="section-subtitle">Applicant self-declaration</div>
                    </div>
                    <div class="section-body">
                        <div class="undertaking-box">
                            <p style="margin: 0; text-align: justify;">
                                मैं <strong><%= student.user ? student.user.name : '-' %></strong> पुत्री/पत्नी <strong><%= student.father_name || '-' %></strong>,
                                कक्षा <strong><%= student.courseName ? student.courseName.name : '' %> - <%= student.semsterName ? student.semsterName.name : '' %></strong>
                                में प्रवेश हेतु यह शपथपूर्वक घोषित करती हूँ कि:
                            </p>
                            <ol>
                                <li>मैंने वर्तमान सत्र में इस महाविद्यालय के अतिरिक्त अन्य किसी विश्वविद्यालय / महाविद्यालय / प्रशिक्षण संस्थान में प्रवेश नहीं लिया है तथा मैं कहीं सेवारत नहीं हूँ।</li>
                                <li>मैं कक्षा में न्यूनतम 75 प्रतिशत उपस्थिति सुनिश्चित करने का वचन देती हूँ।</li>
                                <li>मैं महाविद्यालय के अनुशासन, आचार-संहिता एवं नियमों का पूर्ण पालन करूँगी।</li>
                                <li>मेरे द्वारा आवेदन-पत्र / घोषणा-पत्र में दी गई सभी सूचनाएँ सत्य हैं। कोई सूचना असत्य पाए जाने पर प्रवेश निरस्त किए जाने पर मुझे कोई आपत्ति नहीं होगी।</li>
                                <li>मैं महाविद्यालय परिसर को रैगिंग मुक्त एवं तम्बाकू / गुटखा मुक्त बनाए रखने में सहयोग करूँगी।</li>
                            </ol>

                            <div class="highlight-box">
                                <strong>अभ्यर्थी द्वारा अतिरिक्त अंडरटेकिंग:</strong>
                                <div style="margin-top: 6px; text-align: justify;">
                                    महात्मा गाँधी काशी विद्यापीठ के कार्यालय आदेश दि० 05/09/2020 में प्रोन्नति के सम्बन्ध में दी गयी शर्तों के अधीन अगली कक्षा में प्रोन्नति के पश्चात प्रवेश हेतु मेरा आवेदन किया जा रहा है। यदि भविष्य में विश्वविद्यालय द्वारा पिछली कक्षा में अनुत्तीर्ण घोषित किया जाता है, तो प्रवेश निरस्त किये जाने पर मुझे कोई आपत्ति नहीं होगी।
                                </div>
                            </div>

                            <div class="signature-row">
                                <div class="signature-box">
                                    <div class="signature-line">पिता / अभिभावक के हस्ताक्षर</div>
                                </div>
                                <div class="signature-box">
                                    <div style="border: 1px solid var(--border); border-radius: 8px; height: 62px; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; background: #fff; overflow: hidden;">
                                        <% if (student.sign) { %>
                                            <img src="<%= student.sign %>" alt="Student Sign" style="max-width: 100%; max-height: 100%; object-fit: contain;">
                                        <% } else { %>
                                            <span class="placeholder-text"><%= student.user ? student.user.name : '' %></span>
                                        <% } %>
                                    </div>
                                    <div class="signature-line" style="margin-top: 0;">प्रवेशार्थी के हस्ताक्षर</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="section-card">
                    <div class="section-head">
                        <h3 class="section-title">Required Attachments / Instructions</h3>
                        <div class="section-subtitle">Checklist for office verification</div>
                    </div>
                    <div class="section-body">
                        <div class="instruction-grid">
                            <div>1. हाईस्कूल अंक पत्र एवं प्रमाण-पत्र की छाया प्रति</div>
                            <div>2. इंटरमीडिएट अंक पत्र एवं प्रमाण-पत्र की छाया प्रति</div>
                            <div>3. चरित्र प्रमाण-पत्र की छाया प्रति</div>
                            <div>4. स्थानान्तरण प्रमाण-पत्र (टी.सी.) की छाया प्रति</div>
                            <div>5. जाति प्रमाण-पत्र (SC/ST/OBC हेतु) की छाया प्रति</div>
                            <div>6. आधार कार्ड की छाया प्रति</div>
                            <div>7. अन्य प्रमाण पत्र (भारांक सम्बन्धी) की छाया प्रति</div>
                            <div>8. गैप होने की दशा में शपथ पत्र की छाया प्रति</div>
                        </div>
                    </div>
                </div>

                <div class="receipt-cut"></div>

                <div class="receipt-panel">
                    <div class="receipt-header">फार्म प्राप्ति रसीद</div>
                    <div class="receipt-body">
                        <div style="font-size: 12px; line-height: 1.7; text-align: justify;">
                            <strong>आवेदन पत्र संख्या:</strong> <%= student.registration_no || '-' %><br>
                            छात्रा <strong><%= student.user ? student.user.name : '-' %></strong>, पिता का नाम
                            <strong><%= student.father_name || '-' %></strong>, कक्षा
                            <strong><%= student.courseName ? student.courseName.name : '' %> - <%= student.semsterName ? student.semsterName.name : '' %></strong>
                            में प्रवेश हेतु आवेदन पत्र प्राप्त किया गया।
                        </div>

                        <div class="receipt-footer">
                            <div>
                                <strong>दिनांक:</strong>
                                <%= (typeof payment !== 'undefined' && payment && (payment.txnCompleteDate || payment.transaction_date)) ? new Date(payment.txnCompleteDate || payment.transaction_date).toLocaleString('en-IN') : new Date().toLocaleString('en-IN') %>
                            </div>
                            <div style="min-width: 220px; text-align: center;">
                                <div style="border-bottom: 1px dashed #111827; height: 34px;"></div>
                                <div style="margin-top: 4px; font-weight: 700;">प्राप्तकर्ता के हस्ताक्षर</div>
                            </div>
                        </div>

                        <div style="margin-top: 12px; font-size: 10px; color: var(--muted); font-style: italic;">
                            नोट: एक कागज पर हस्ताक्षर और फोटो भी फार्म के साथ संलग्न करें।
                        </div>

                        <div class="footer-mini-header">
                            <img src="/uploads/static/logo_header.png" alt="Logo" style="max-height: 34px;">
                            <div>
                                Government Women Degree College Robertsganj Sonebhadra<br>
                                <span class="small muted">राजकीय महिला महाविद्यालय रॉबर्ट्सगंज सोनभद्र</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-center no-print mt-20">
                    <button onclick="window.print()" class="btn btn-dark btn-sm">Final Print Application</button>
                </div>
            <% } else { %>
                <div class="empty-state">Student record not found.</div>
            <% } %>
        </div>
    </div>

    <div class="no-print">
        <% if (typeof layout !== 'undefined' && layout === 'frontend') { %>
            <%- include('../../../frontend/layout/footer') %>
        <% } else if (typeof layout !== 'undefined' && layout === 'student') { %>
            <%- include('../../../student_panel/layout/footer') %>
        <% } %>
    </div>

    <%- include('../../layout/script_link') %>
</body>
</html>

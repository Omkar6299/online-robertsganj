<div id="upload-error-container"></div>

<div class="row g-4">
    <% if (typeof documentMappings !== 'undefined' && documentMappings.length > 0) { %>
        <% documentMappings.forEach(function(mapping) { %>
            <% 
                const docType = mapping.documentType;
                const isRequired = mapping.is_required === 'Required';
                const isHidden = mapping.is_required === 'Hidden';
                const uploadedDoc = typeof uploadedDocsMap !== 'undefined' ? uploadedDocsMap[docType.code] : null;
                
                if (isHidden) return;
            %>
            <div class="col-md-6">
                <div class="card h-100 border-light shadow-sm">
                    <div class="card-body">
                        <label class="form-label fw-bold">
                            <%= docType.name %> 
                            <% if (isRequired) { %><span class="text-danger">*</span><% } %>
                        </label>
                        
                        <div class="input-group mb-2">
                            <input type="file" 
                                   class="form-control dynamic-upload" 
                                   data-code="<%= docType.code %>"
                                   id="file_<%= docType.code %>"
                                   accept="image/*,application/pdf"
                                   <%= (!uploadedDoc && isRequired) ? 'required' : '' %>>
                        </div>

                        <div class="progress mb-2 d-none" id="progress_container_<%= docType.code %>" style="height: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                 id="progress_bar_<%= docType.code %>" 
                                 role="progressbar" style="width: 0%"></div>
                        </div>

                        <div id="preview_container_<%= docType.code %>" class="mt-2 text-center">
                            <% if (uploadedDoc) { %>
                                <% if (uploadedDoc.file_path.match(/\.(jpg|jpeg|png|gif|jfif)$/i)) { %>
                                    <img src="<%= uploadedDoc.file_path %>" class="img-thumbnail" style="max-height: 150px;">
                                <% } else if (uploadedDoc.file_path.match(/\.pdf$/i)) { %>
                                    <div class="alert alert-info py-2">
                                        <i class="bi bi-file-earmark-pdf"></i> PDF Uploaded
                                        <a href="<%= uploadedDoc.file_path %>" target="_blank" class="ms-2 btn btn-sm btn-outline-primary">View</a>
                                    </div>
                                <% } %>
                            <% } else { %>
                                <p class="text-muted small">No file uploaded yet</p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="col-12">
            <div class="alert alert-warning">
                No documents are configured for your course/semester. Please contact admin.
            </div>
        </div>
    <% } %>
</div>

<div class="mt-5 d-flex justify-content-between border-top pt-3">
    <a href="/student/registration?tab=<%= typeof isReRegistration !== 'undefined' && isReRegistration ? 'other' : 'weightage' %>" class="btn btn-outline-secondary px-4">
        <i class="bi bi-arrow-left"></i> Previous
    </a>
    <button type="button" id="btn-continue-declaration" class="btn btn-primary px-5">
        Save & Continue <i class="bi bi-arrow-right"></i>
    </button>
</div>

<script>
document.querySelectorAll('.dynamic-upload').forEach(input => {
    input.addEventListener('change', function(e) {
        const file = e.target.files[0];
        const code = this.dataset.code;
        if (!file) return;

        // Validation
        const maxSize = 5 * 1024 * 1024; // 5MB
        if (file.size > maxSize) {
            alert('File size exceeds 5MB limit.');
            this.value = '';
            return;
        }

        uploadFile(file, code);
    });
});

async function uploadFile(file, code) {
    const formData = new FormData();
    formData.append(code, file);

    const progressContainer = document.getElementById(`progress_container_${code}`);
    const progressBar = document.getElementById(`progress_bar_${code}`);
    const previewContainer = document.getElementById(`preview_container_${code}`);

    progressContainer.classList.remove('d-none');
    progressBar.style.width = '0%';
    progressBar.classList.add('bg-primary');

    try {
        const xhr = new XMLHttpRequest();
        xhr.open('POST', '/student/photograph_sign_details_post', true);
        xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

        xhr.upload.onprogress = (e) => {
            if (e.lengthComputable) {
                const percent = Math.round((e.loaded / e.total) * 100);
                progressBar.style.width = percent + '%';
            }
        };

        xhr.onload = function() {
            if (xhr.status === 200) {
                const response = JSON.parse(xhr.responseText);
                progressBar.classList.remove('bg-primary');
                progressBar.classList.add('bg-success');
                
                // Show preview
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = (e) => {
                        previewContainer.innerHTML = `<img src="${e.target.result}" class="img-thumbnail" style="max-height: 150px;">`;
                    };
                    reader.readAsDataURL(file);
                } else if (file.type === 'application/pdf') {
                    previewContainer.innerHTML = `
                        <div class="alert alert-success py-2">
                            <i class="bi bi-file-earmark-pdf"></i> ${file.name} Uploaded Successfully
                        </div>`;
                }
                
                setTimeout(() => {
                    progressContainer.classList.add('d-none');
                }, 2000);
            } else {
                const response = JSON.parse(xhr.responseText);
                alert('Upload failed: ' + (response.message || 'Unknown error'));
                progressBar.classList.add('bg-danger');
            }
        };

        xhr.onerror = function() {
            alert('Network error occurred.');
            progressBar.classList.add('bg-danger');
        };

        xhr.send(formData);
    } catch (error) {
        console.error('Upload Error:', error);
        alert('An unexpected error occurred.');
    }
}

document.getElementById('btn-continue-declaration').addEventListener('click', function() {
    // Check if required files are uploaded
    const requiredInputs = document.querySelectorAll('.dynamic-upload[required]');
    let allUploaded = true;
    
    requiredInputs.forEach(input => {
        const code = input.dataset.code;
        const preview = document.getElementById(`preview_container_${code}`);
        if (preview.innerHTML.includes('No file uploaded yet') && !input.files.length) {
            allUploaded = false;
            input.classList.add('is-invalid');
        } else {
            input.classList.remove('is-invalid');
        }
    });

    if (!allUploaded) {
        alert('Please upload all required documents before continuing.');
        return;
    }

    window.location.href = '/student/registration?tab=declaration';
});
</script>

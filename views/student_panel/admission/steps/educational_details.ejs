<% if (typeof errors !== 'undefined' && errors.length > 0) { %>
    <div class="alert alert-danger">
        <ul class="mb-0">
            <% errors.forEach(function(error) { %>
                <li><%= error %></li>
            <% }); %>
        </ul>
    </div>
<% } %>

<form action="/student/educational_details_post" method="POST">
    <div class="row g-3">
        <% if (typeof qualifications !== 'undefined' && qualifications.length > 0) { %>
            <% qualifications.forEach(function(qualification, index) { %>
                <% if (qualification.status !== 'hidden') { %>
                <div class="col-md-12">
                    <h5><%= qualification.name %> <%= qualification.status === 'optional' ? '(Optional)' : '' %></h5>
                    <input type="hidden" name="qual_name[<%= qualification.id %>]" value="<%= qualification.name %>">
                </div>

                <div class="col-md-5">
                    <div class="form-group">
                        <label for="board_<%= qualification.id %>" class="form-label">Board/University <span class="<%= qualification.status === 'required' ? 'text-danger' : '' %>"><%= qualification.status === 'required' ? '*' : '' %></span></label>
                        <input type="text" name="board[<%= qualification.id %>]" id="board_<%= qualification.id %>" class="form-control"
                            value="<%= typeof oldInput !== 'undefined' && oldInput.board && oldInput.board[qualification.id] ? oldInput.board[qualification.id] : (typeof educationalDetails !== 'undefined' && educationalDetails[qualification.name] && educationalDetails[qualification.name].board_name ? educationalDetails[qualification.name].board_name : '') %>"
                            placeholder="Enter Board/University" <%= qualification.status === 'required' ? 'required' : '' %>>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="form-group">
                        <label for="year_<%= qualification.id %>" class="form-label">Passing Year <span class="<%= qualification.status === 'required' ? 'text-danger' : '' %>"><%= qualification.status === 'required' ? '*' : '' %></span></label>
                        <% if (qualification.max_year_gap !== null && qualification.max_year_gap !== undefined) { %>
                            <select name="year[<%= qualification.id %>]" id="year_<%= qualification.id %>" class="form-control" <%= qualification.status === 'required' ? 'required' : '' %>>
                                <option value="">-- Select Year --</option>
                                <%
                                    const availableYears = [];
                                    const currentYr = typeof currentYear !== 'undefined' ? currentYear : new Date().getFullYear();
                                    for(let i = 0; i <= qualification.max_year_gap; i++) {
                                        availableYears.push(currentYr - i);
                                    }
                                %>
                                <% availableYears.forEach(year => { %>
                                    <option value="<%= year %>"
                                        <%= (typeof oldInput !== 'undefined' && oldInput.year && oldInput.year[qualification.id] == year) || (typeof educationalDetails !== 'undefined' && educationalDetails[qualification.name] && educationalDetails[qualification.name].year_of_passing == year) ? 'selected' : '' %>>
                                        <%= year %>
                                    </option>
                                <% }); %>
                            </select>
                        <% } else { %>
                            <select name="year[<%= qualification.id %>]" id="year_<%= qualification.id %>" class="form-control" <%= qualification.status === 'required' ? 'required' : '' %>>
                                <option value="">-- Select Year --</option>
                                <%
                                    const defaultYears = [];
                                    const currYr = typeof currentYear !== 'undefined' ? currentYear : new Date().getFullYear();
                                    for(let i = 0; i <= 50; i++) {
                                        defaultYears.push(currYr - i);
                                    }
                                %>
                                <% defaultYears.forEach(year => { %>
                                    <option value="<%= year %>"
                                        <%= (typeof oldInput !== 'undefined' && oldInput.year && oldInput.year[qualification.id] == year) || (typeof educationalDetails !== 'undefined' && educationalDetails[qualification.name] && educationalDetails[qualification.name].year_of_passing == year) ? 'selected' : '' %>>
                                        <%= year %>
                                    </option>
                                <% }); %>
                            </select>
                        <% } %>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-group">
                        <label for="roll_no_<%= qualification.id %>" class="form-label">Roll Number</label>
                        <input type="text" name="roll_no[<%= qualification.id %>]" id="roll_no_<%= qualification.id %>" class="form-control"
                            value="<%= typeof oldInput !== 'undefined' && oldInput.roll_no && oldInput.roll_no[qualification.id] ? oldInput.roll_no[qualification.id] : (typeof educationalDetails !== 'undefined' && educationalDetails[qualification.name] && educationalDetails[qualification.name].roll_no ? educationalDetails[qualification.name].roll_no : '') %>"
                            placeholder="Enter Roll Number">
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group">
                        <label for="subject_details_<%= qualification.id %>" class="form-label">Subject(s) Taken <span class="<%= qualification.status === 'required' ? 'text-danger' : '' %>"><%= qualification.status === 'required' ? '*' : '' %></span></label>
                        <input type="text" name="subject_details[<%= qualification.id %>]" id="subject_details_<%= qualification.id %>" class="form-control"
                            value="<%= typeof oldInput !== 'undefined' && oldInput.subject_details && oldInput.subject_details[qualification.id] ? oldInput.subject_details[qualification.id] : (typeof educationalDetails !== 'undefined' && educationalDetails[qualification.name] && educationalDetails[qualification.name].subject_details ? educationalDetails[qualification.name].subject_details : '') %>"
                            placeholder="Enter subjects (e.g., Hindi, English, Science, Mathematics...)" <%= qualification.status === 'required' ? 'required' : '' %>>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        <label for="total_marks_<%= qualification.id %>" class="form-label">Total Marks <span class="<%= qualification.status === 'required' ? 'text-danger' : '' %>"><%= qualification.status === 'required' ? '*' : '' %></span></label>
                        <input type="number" name="total_marks[<%= qualification.id %>]" id="total_marks_<%= qualification.id %>" class="form-control" min="0" step="any"
                            value="<%= typeof oldInput !== 'undefined' && oldInput.total_marks && oldInput.total_marks[qualification.id] ? oldInput.total_marks[qualification.id] : (typeof educationalDetails !== 'undefined' && educationalDetails[qualification.name] && educationalDetails[qualification.name].total_marks ? educationalDetails[qualification.name].total_marks : '') %>"
                            placeholder="Total Marks" <%= qualification.status === 'required' ? 'required' : '' %>>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        <label for="obtained_marks_<%= qualification.id %>" class="form-label">Obtained Marks <span class="<%= qualification.status === 'required' ? 'text-danger' : '' %>"><%= qualification.status === 'required' ? '*' : '' %></span></label>
                        <input type="number" name="obtained_marks[<%= qualification.id %>]" id="obtained_marks_<%= qualification.id %>" class="form-control" min="0" step="any"
                            value="<%= typeof oldInput !== 'undefined' && oldInput.obtained_marks && oldInput.obtained_marks[qualification.id] ? oldInput.obtained_marks[qualification.id] : (typeof educationalDetails !== 'undefined' && educationalDetails[qualification.name] && educationalDetails[qualification.name].obtained_marks ? educationalDetails[qualification.name].obtained_marks : '') %>"
                            placeholder="Obtained Marks" <%= qualification.status === 'required' ? 'required' : '' %>>
                    </div>
                </div>

                <!-- Hidden fields for compatibility with older Mark Type logic if needed -->
                <input type="hidden" name="mark_type[<%= qualification.id %>]" value="Percentage">
                <input type="hidden" name="percentage[<%= qualification.id %>]" id="percentage_<%= qualification.id %>">
                <input type="hidden" name="cgpa[<%= qualification.id %>]" id="cgpa_<%= qualification.id %>">
                <% } %>
            <% }); %>
        <% } %>
    </div>

    <div class="mt-4 d-flex justify-content-between">
        <a href="/student/registration?tab=address" class="btn btn-secondary">Previous</a>
        <button type="submit" class="btn btn-primary">Save & Continue</button>
    </div>
</form>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const totalInputs = document.querySelectorAll('input[name^="total_marks"]');
        const obtainedInputs = document.querySelectorAll('input[name^="obtained_marks"]');

        function validateMarks(qualId) {
            const totalInput = document.getElementById(`total_marks_${qualId}`);
            const obtainedInput = document.getElementById(`obtained_marks_${qualId}`);
            if (!totalInput || !obtainedInput) return true;

            const total = parseFloat(totalInput.value);
            const obtained = parseFloat(obtainedInput.value);

            let errorEl = document.getElementById(`marks_error_${qualId}`);
            if (!errorEl) {
                errorEl = document.createElement('div');
                errorEl.id = `marks_error_${qualId}`;
                errorEl.className = 'text-danger small mt-1';
                obtainedInput.parentNode.appendChild(errorEl);
            }

            if (!isNaN(total) && !isNaN(obtained) && obtained > total) {
                errorEl.textContent = `Obtained marks (${obtained}) cannot exceed Total marks (${total}).`;
                obtainedInput.classList.add('is-invalid');
                return false;
            } else {
                errorEl.textContent = '';
                obtainedInput.classList.remove('is-invalid');
                return true;
            }
        }

        totalInputs.forEach(input => {
            const qualId = input.id.replace('total_marks_', '');
            input.addEventListener('input', () => validateMarks(qualId));
        });

        obtainedInputs.forEach(input => {
            const qualId = input.id.replace('obtained_marks_', '');
            input.addEventListener('input', () => validateMarks(qualId));
        });

        const form = document.querySelector('form[action="/student/educational_details_post"]');
        if (form) {
            form.addEventListener('submit', function(e) {
                let hasError = false;
                totalInputs.forEach(input => {
                    const qualId = input.id.replace('total_marks_', '');
                    if (!validateMarks(qualId)) {
                        hasError = true;
                    }
                });
                if (hasError) {
                    e.preventDefault();
                    const firstInvalid = document.querySelector('.is-invalid');
                    if (firstInvalid) {
                        firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
            });
        }
    });
</script>

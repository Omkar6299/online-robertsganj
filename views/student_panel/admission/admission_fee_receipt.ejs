<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layout/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Admission Fee Receipt' %></title>
    <style>
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background-color: #f4f7f6;
            margin: 0;
            padding: 0;
        }
        
        /* Scrollable container for web view */
        .receipt-scroll-container {
            max-height: 80vh;
            overflow-y: auto;
            padding: 20px 0;
            background: #f4f7f6;
        }

        .receipt-container { 
            max-width: 800px; 
            margin: 0 auto; 
            background: #fff; 
            padding: 40px; 
            box-shadow: 0 4px 20px rgba(0,0,0,0.1); 
            border-radius: 8px; 
        }

        .receipt-header { 
            border-bottom: 2px solid #eee; 
            padding-bottom: 20px; 
            margin-bottom: 30px; 
            display: flex; 
            align-items: center; 
            justify-content: space-between; 
        }

        .college-info h2 { margin: 0; color: #333; font-size: 24px; font-weight: 700; }
        .college-info p { margin: 5px 0 0; color: #666; font-size: 14px; }
        .receipt-title { background: #007bff; color: #fff; padding: 5px 15px; border-radius: 4px; font-weight: 600; text-transform: uppercase; font-size: 14px; }
        .detail-row { display: flex; margin-bottom: 12px; border-bottom: 1px dashed #f0f0f0; padding-bottom: 8px; }
        .detail-label { width: 40%; font-weight: 600; color: #555; }
        .detail-value { width: 60%; color: #333; }
        .amount-section { background: #f8f9fa; border-radius: 6px; padding: 20px; margin-top: 30px; display: flex; justify-content: space-between; align-items: center; border-left: 5px solid #28a745; }
        .amount-label { font-size: 18px; font-weight: 600; color: #444; }
        .amount-value { font-size: 24px; font-weight: 700; color: #28a745; }
        .footer-note { margin-top: 40px; font-size: 12px; color: #888; text-align: center; line-height: 1.6; }
        .signature-section { margin-top: 50px; display: flex; justify-content: flex-end; }
        .signature-box { text-align: center; width: 200px; border-top: 1px solid #333; padding-top: 10px; font-weight: 600; font-size: 14px; }

        @media print {
            .no-print { display: none !important; }
            body { background: #fff !important; }
            .receipt-scroll-container {
                max-height: none !important;
                overflow: visible !important;
                padding: 0 !important;
                background: #fff !important;
            }
            .receipt-container { 
                box-shadow: none !important; 
                margin: 0 !important; 
                max-width: 100% !important; 
                border: none !important; 
                padding: 10mm !important;
            }
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
        }
    </style>
</head>
<body>
    <div class="no-print">
        <% if (typeof layout !== 'undefined' && layout === 'student') { %>
            <%- include('../layout/header') %>
        <% } %>
    </div>

    <div class="container no-print mt-4 text-center">
        <button onclick="window.print()" class="btn btn-primary btn-sm"><i class="bi bi-printer"></i> Print Receipt</button>
        <% if (typeof layout !== 'undefined' && layout === 'student') { %>
            <a href="/student/dashboard" class="btn btn-secondary btn-sm"><i class="bi bi-house"></i> Back to Dashboard</a>
        <% } %>
    </div>

    <div class="receipt-scroll-container">
        <div class="receipt-container">
            <div class="receipt-header">
                <div class="college-info">
                    <h2><%= fieldLabels.header.college_name_hi %></h2>
                    <p><%= fieldLabels.header.college_address_hi %></p>
                    <p><strong><%= fieldLabels.header.admission_receipt_title %></strong></p>
                </div>
                <div class="receipt-title">Paid Successful</div>
            </div>

            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="detail-row">
                        <div class="detail-label"><%= fieldLabels.receipt.fields.reg_no %>:</div>
                        <div class="detail-value"><strong><%= payment.registration_no %></strong></div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label"><%= fieldLabels.receipt.fields.name %>:</div>
                        <div class="detail-value"><%= user.name %></div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label"><%= fieldLabels.receipt.fields.father_name %>:</div>
                        <div class="detail-value"><%= student.father_name %></div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label"><%= fieldLabels.application.fields.dob %>:</div>
                        <div class="detail-value"><%= student.dob %></div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label">Phone:</div>
                        <div class="detail-value"><%= user.phone %></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-row">
                        <div class="detail-label"><%= fieldLabels.receipt.fields.academic_year %>:</div>
                        <div class="detail-value"><%= activeYear ? activeYear.session : 'N/A' %></div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label"><%= fieldLabels.receipt.fields.course %>:</div>
                        <div class="detail-value"><%= student.courseName ? student.courseName.name : 'N/A' %></div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label"><%= fieldLabels.receipt.fields.semester %>:</div>
                        <div class="detail-value"><%= payment.semester ? payment.semester.name : (student.semsterName ? student.semsterName.name : 'N/A') %></div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label"><%= fieldLabels.receipt.fields.txn_id %>:</div>
                        <div class="detail-value"><small><%= payment.merchant_txn_id %></small></div>
                    </div>
                    <div class="detail-row">
                        <div class="detail-label"><%= fieldLabels.receipt.fields.txn_date %>:</div>
                        <div class="detail-value"><%= new Date(payment.payment_date || payment.createdAt).toLocaleString('en-IN') %></div>
                    </div>
                </div>
            </div>

            <div class="amount-section">
                <div class="amount-label">Admission Fee Paid</div>
                <div class="amount-value">₹ <%= payment.amount %></div>
            </div>

            <div class="signature-section">
                <div class="signature-box">
                    Authorized Signatory
                </div>
            </div>

            <div class="footer-note">
                <p>This is a computer-generated receipt and does not require a physical signature.</p>
                <p>Please keep this receipt for future reference during the admission process.</p>
            </div>
        </div>
    </div>

    <div class="no-print">
        <% if (typeof layout !== 'undefined' && layout === 'student') { %>
            <%- include('../layout/footer') %>
        <% } %>
        <%- include('../layout/script_link') %>
    </div>
</body>
</html>

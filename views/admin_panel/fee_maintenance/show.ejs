<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Fee Details' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0">Fee Maintenance Details</h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item"><a href="/admin/fee_maintenance">Fee Maintenance</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Details</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="card shadow-sm mb-4">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="mb-0">Record Information</h5>
                                        </div>
                                        <div class="col-md-6 d-flex justify-content-end align-items-center">
                                            <a class="btn btn-bg-primary me-2" href="/admin/fee_maintenance">Return</a>
                                            <a class="btn btn-warning" href="/admin/fee_maintenance/<%= fee.id %>/edit">
                                                <i class="bi bi-pencil me-1"></i> Edit
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="row g-4">
                                        <div class="col-md-4">
                                            <label class="fw-bold text-muted d-block small text-uppercase">Course</label>
                                            <span class="fs-5"><%= fee.course ? fee.course.name : fee.Course %></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="fw-bold text-muted d-block small text-uppercase">Semester</label>
                                            <span class="fs-5"><%= fee.semesterInfo ? fee.semesterInfo.name : fee.semester %></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="fw-bold text-muted d-block small text-uppercase">Fee Name</label>
                                            <span class="fs-5"><%= fee.Fee_Name %></span>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="fw-bold text-muted d-block small text-uppercase">Status</label>
                                            <span class="badge <%= (fee.fee_Active == 'Active' || fee.fee_Active == '1') ? 'bg-success' : 'bg-danger' %>">
                                                <%= fee.fee_Active %>
                                            </span>
                                        </div>
                                        <div class="col-md-4">
                                            <label class="fw-bold text-muted d-block small text-uppercase">Last Updated By</label>
                                            <span class="fs-5"><%= fee.User %></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="card shadow-sm">
                                        <div class="card-header bg-light">
                                            <h6 class="mb-0">Fee Amounts (INR)</h6>
                                        </div>
                                        <div class="card-body p-0">
                                            <table class="table table-striped mb-0">
                                                <tr>
                                                    <th class="ps-3 w-50">Total Fee Amount</th>
                                                    <td class="text-end pe-3 fw-bold">₹ <%= fee.Total_Fee_Amount %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-3">General Fee Amount</th>
                                                    <td class="text-end pe-3">₹ <%= fee.General_fee_Amount %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-3">Girls Fee Amount</th>
                                                    <td class="text-end pe-3">₹ <%= fee.Girls_fee_Amount %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-3">OBC Fee Amount</th>
                                                    <td class="text-end pe-3">₹ <%= fee.OBC_fee_Amount %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-3">SC Fee Amount</th>
                                                    <td class="text-end pe-3">₹ <%= fee.SC_fee_Amount %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-3">ST Fee Amount</th>
                                                    <td class="text-end pe-3">₹ <%= fee.ST_fee_Amount %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-3">Minority Fee Amount</th>
                                                    <td class="text-end pe-3">₹ <%= fee.Minority_Fee_Amount %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-3">Practical Fee</th>
                                                    <td class="text-end pe-3">₹ <%= fee.Practical_Fee %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-3">Late Fee (INR)</th>
                                                    <td class="text-end pe-3 fw-bold">₹ <%= fee.late_fee %></td>
                                                </tr>
                                                <tr>
                                                    <th class="ps-3">Late Fee Status</th>
                                                    <td class="text-end pe-3">
                                                        <span class="badge <%= fee.is_late_fee_applicable ? 'bg-primary' : 'bg-secondary' %>">
                                                            <%= fee.is_late_fee_applicable ? 'Late Fee Enabled' : 'Disabled' %>
                                                        </span>
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="card shadow-sm h-100">
                                        <div class="card-header bg-light">
                                            <h6 class="mb-0">Classification & Type Info</h6>
                                        </div>
                                        <div class="card-body">
                                            <div class="mb-3 border-bottom pb-2">
                                                <label class="fw-bold text-muted small text-uppercase d-block">Fee Type</label>
                                                <span><%= fee.fee_Type || '-' %></span>
                                            </div>
                                            <div class="mb-3 border-bottom pb-2">
                                                <label class="fw-bold text-muted small text-uppercase d-block">Student Type</label>
                                                <span><%= fee.Student_Type || '-' %></span>
                                            </div>
                                            <div class="mb-3 border-bottom pb-2">
                                                <label class="fw-bold text-muted small text-uppercase d-block">Ex-Student</label>
                                                <span><%= fee.Ex_Student %></span>
                                            </div>
                                            <div class="mb-0">
                                                <label class="fw-bold text-muted small text-uppercase d-block">Lab Fee Type</label>
                                                <span><%= fee.Lab_Fee_Type || '-' %></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Session Management' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Session Management' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><%= typeof title !== 'undefined' ? title : 'Session Management' %></li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12 col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Sessions' %></h5>
                                        </div>
                                        <div class="col-md-6 d-flex justify-content-end align-items-center">
                                            <a class="btn btn-bg-primary" href="/admin/academic-years/create">Add Session</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <% if (typeof success !== 'undefined' && success.length > 0) { %>
                                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                                            <%= success.join(', ') %>
                                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                        </div>
                                    <% } %>
                                    <% if (typeof error !== 'undefined' && error.length > 0) { %>
                                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                            <%= error.join(', ') %>
                                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                        </div>
                                    <% } %>

                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle" id="dataTable">
                                            <thead class="table-bg-primary">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Session</th>
                                                    <th>Status</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof academicYears !== 'undefined' && academicYears.length > 0) { %>
                                                    <% academicYears.forEach(function(year, index) { %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><%= year.session %></td>
                                                            <td>
                                                                <% if (year.status == 'Active') { %>
                                                                    <span class="badge bg-success">Active</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-danger">Inactive</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <a href="/admin/academic-years/<%= year.id %>/edit"
                                                                    class="btn btn-sm btn-warning">
                                                                    <i class="bi bi-pencil"></i> Edit
                                                                </a>
                                                                
                                                                <% if (year.status !== 'Active') { %>
                                                                    <form action="/admin/academic-years/<%= year.id %>" method="POST" class="d-inline"
                                                                        onsubmit="return confirm('Warning: Activating this session will automatically deactivate the currently active session. Do you want to proceed?');">
                                                                        <input type="hidden" name="_method" value="PATCH">
                                                                        <button type="submit" class="btn btn-sm btn-success">
                                                                            <i class="bi bi-check-circle"></i> Activate
                                                                        </button>
                                                                    </form>
                                                                <% } %>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="4" class="text-center">No sessions found.</td>
                                                    </tr>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
    <%- include('../layouts/datatable_init') %>
</body>
</html>

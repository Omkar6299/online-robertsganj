<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Subject Wise Report' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Subject Wise Report' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><%= typeof title !== 'undefined' ? title : 'Subject Wise Report' %></li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12 col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Subject Wise Report' %></h5>
                                </div>
                                <div class="card-body">
                                    <form action="/admin/reports/subject_wise" method="GET" class="row g-3 mb-4">
                                        <div class="col-md-4">
                                            <label for="course_id" class="form-label">Course</label>
                                            <select name="course_id" id="course_id" class="form-control">
                                                <option value="">All Courses</option>
                                                <% if (typeof courses !== 'undefined' && courses.length > 0) { %>
                                                    <% courses.forEach(function(course) { %>
                                                        <option value="<%= course.id %>" <%= typeof oldInput !== 'undefined' && oldInput.course_id == course.id ? 'selected' : '' %>>
                                                            <%= course.name %>
                                                        </option>
                                                    <% }); %>
                                                <% } %>
                                            </select>
                                        </div>
                                        <div class="col-md-4">
                                            <label for="subject_id" class="form-label">Subject</label>
                                            <select name="subject_id" id="subject_id" class="form-control">
                                                <option value="">All Subjects</option>
                                                <% if (typeof subjects !== 'undefined' && subjects.length > 0) { %>
                                                    <% subjects.forEach(function(subject) { %>
                                                        <option value="<%= subject.id %>" <%= typeof oldInput !== 'undefined' && oldInput.subject_id == subject.id ? 'selected' : '' %>>
                                                            <%= subject.name %>
                                                        </option>
                                                    <% }); %>
                                                <% } %>
                                            </select>
                                        </div>
                                        <div class="col-md-4 d-flex align-items-end">
                                            <button type="submit" class="btn btn-primary w-100">Filter</button>
                                        </div>
                                    </form>

                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle" id="dataTable">
                                            <thead class="table-bg-primary">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Registration No</th>
                                                    <th>Student Name</th>
                                                    <th>Course</th>
                                                    <th>Subject</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof allocations !== 'undefined' && allocations.length > 0) { %>
                                                    <% allocations.forEach(function(allocation, index) { %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><%= allocation.student && allocation.student.registration_no ? allocation.student.registration_no : '-' %></td>
                                                            <td><%= allocation.student && allocation.student.user && allocation.student.user.name ? allocation.student.user.name : '-' %></td>
                                                            <td><%= allocation.student && allocation.student.courseName && allocation.student.courseName.name ? allocation.student.courseName.name : '-' %></td>
                                                            <td><%= allocation.subject && allocation.subject.name ? allocation.subject.name : '-' %></td>
                                                        </tr>
                                                    <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="5" class="text-center">No records found.</td>
                                                    </tr>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
    <%- include('../layouts/datatable_init') %>
</body>
</html>


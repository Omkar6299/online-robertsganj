<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Permissions' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Permissions' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><%= typeof title !== 'undefined' ? title : 'Permissions' %></li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12 col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Permissions' %></h5>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle" id="dataTable">
                                            <thead class="table-bg-primary">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Permission Name</th>
                                                    <th>Guard Name</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof permissions !== 'undefined' && permissions.length > 0) { %>
                                                    <% permissions.forEach(function(permission, index) { %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><%= permission.name %></td>
                                                            <td><%= permission.guard_name || 'web' %></td>
                                                        </tr>
                                                    <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="3" class="text-center">No permissions found.</td>
                                                    </tr>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
    <%- include('../layouts/datatable_init') %>
</body>
</html>


<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Course Semester Documents' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0">Document Mapping</h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Document Mapping</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6 text-start">
                                            <h5 class="mb-0">Manage Course & Semester Documents</h5>
                                        </div>
                                        <div class="col-md-6 text-end">
                                            <a class="btn btn-bg-primary" href="/admin/course_semester_documents/create">Add Mapping</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <!-- Filter Form -->
                                    <form action="/admin/course_semester_documents" method="GET" class="mb-4 bg-light p-3 border rounded shadow-xs" id="filterForm">
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label for="course_id_filter" class="form-label small fw-bold">Filter by Course</label>
                                                    <select name="course_id" id="course_id_filter" class="form-control form-control-sm">
                                                        <option value="">-- All Courses --</option>
                                                        <% if(typeof courses !== 'undefined' && courses.length > 0) { %>
                                                            <% courses.forEach(function(course) { %>
                                                                <option value="<%= course.id %>" <%= typeof selectedCourseId !== 'undefined' && selectedCourseId == course.id ? 'selected' : '' %>><%= course.name %></option>
                                                            <% }); %>
                                                        <% } %>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label for="semester_id_filter" class="form-label small fw-bold">Filter by Semester</label>
                                                    <select name="semester_id" id="semester_id_filter" class="form-control form-control-sm" <%= (typeof selectedCourseId !== 'undefined' && selectedCourseId) ? '' : 'disabled' %>>
                                                        <option value="">-- All Semesters --</option>
                                                        <% if(typeof semesters !== 'undefined' && semesters.length > 0) { %>
                                                            <% semesters.forEach(function(sem) { %>
                                                                <option value="<%= sem.id %>" <%= typeof selectedSemesterId !== 'undefined' && selectedSemesterId == sem.id ? 'selected' : '' %>><%= sem.name %></option>
                                                            <% }); %>
                                                        <% } %>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4 d-flex align-items-end gap-2">
                                                <button type="submit" class="btn btn-primary btn-sm px-4">
                                                    <i class="bi bi-filter"></i> Filter
                                                </button>
                                                <button type="button" class="btn btn-secondary btn-sm px-4" id="resetBtn">
                                                    <i class="bi bi-x-circle"></i> Reset
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle" id="dataTable">
                                            <thead class="table-dark">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Course</th>
                                                    <th>Semester</th>
                                                    <th>Document</th>
                                                    <th>Requirement</th>
                                                    <th>Status</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof mappings !== 'undefined' && mappings.length > 0) { %>
                                                    <% mappings.forEach(function(item, index) { %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><%= item.course ? item.course.name : '-' %></td>
                                                            <td><%= item.semester ? item.semester.name : '-' %></td>
                                                            <td><%= item.documentType ? item.documentType.name : '-' %></td>
                                                            <td>
                                                                <span class="badge bg-<%= item.is_required === 'Required' ? 'danger' : (item.is_required === 'Optional' ? 'info' : 'secondary') %>">
                                                                    <%= item.is_required %>
                                                                </span>
                                                            </td>
                                                            <td>
                                                                <% if (item.status) { %>
                                                                    <span class="badge bg-success">Active</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-danger">Inactive</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <a href="/admin/course_semester_documents/<%= item.id %>/edit" class="btn btn-sm btn-warning">
                                                                    <i class="bi bi-pencil"></i> Edit
                                                                </a>
                                                                <form action="/admin/course_semester_documents/<%= item.id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this mapping?');">
                                                                    <input type="hidden" name="_method" value="DELETE">
                                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                                        <i class="bi bi-trash"></i> Delete
                                                                    </button>
                                                                </form>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="7" class="text-center">No mappings found.</td>
                                                    </tr>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
    <%- include('../layouts/datatable_init') %>
    <script>
        $(document).ready(function() {
            // Course -> Semester AJAX
            $('#course_id_filter').change(async function() {
                const courseId = $(this).val();
                const semSelect = $('#semester_id_filter');
                semSelect.empty().append('<option value="">-- All Semesters --</option>');
                
                if (courseId) {
                    semSelect.prop('disabled', true);
                    try {
                        const response = await fetch(`/admin/course_semester_documents/get-semesters/${courseId}`);
                        const semesters = await response.json();
                        
                        semesters.forEach(sem => {
                            semSelect.append(`<option value="${sem.id}">${sem.name}</option>`);
                        });
                        semSelect.prop('disabled', false);
                    } catch (error) {
                        console.error('Error fetching semesters:', error);
                    }
                } else {
                    semSelect.prop('disabled', true);
                }
            });

            // Reset Button
            $('#resetBtn').click(function() {
                window.location.href = '/admin/course_semester_documents';
            });
        });
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Edit Subject' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Edit Subject' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item"><a href="/admin/subjects">Subjects</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><%= typeof title !== 'undefined' ? title : 'Edit Subject' %></li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12 col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Edit Subject' %></h5>
                                        </div>
                                        <div class="col-md-6 d-flex justify-content-end align-items-center">
                                            <a class="btn btn-bg-primary" href="/admin/subjects">Return</a>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-body">
                                    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                                        <div class="alert alert-danger">
                                            <ul class="mb-0">
                                                <% errors.forEach(function(error) { %>
                                                    <li><%= error %></li>
                                                <% }); %>
                                            </ul>
                                        </div>
                                    <% } %>

                                    <form action="/admin/subjects/<%= typeof subject !== 'undefined' ? subject.id : '' %>" method="POST">
                                        <input type="hidden" name="_method" value="PUT">
                                        <div class="row g-3">
                                            <!-- Course -->
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="course_id" class="form-label">Course <span class="text-danger">*</span></label>
                                                    <select name="course_id" id="course_id" class="form-control" required>
                                                        <option value="">-- Select Course --</option>
                                                        <% if (typeof courses !== 'undefined' && courses.length > 0) { %>
                                                            <% courses.forEach(function(course) { %>
                                                                <option value="<%= course.id %>" <%= (typeof subject !== 'undefined' && subject.course_id == course.id) || (typeof oldInput !== 'undefined' && oldInput.course_id == course.id) ? 'selected' : '' %>>
                                                                    <%= course.name %>
                                                                </option>
                                                            <% }); %>
                                                        <% } %>
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- Subject Name -->
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="subject_name" class="form-label">Subject Name <span class="text-danger">*</span></label>
                                                    <input type="text" name="subject_name" id="subject_name" class="form-control"
                                                        value="<%= typeof oldInput !== 'undefined' && oldInput.subject_name ? oldInput.subject_name : (typeof subject !== 'undefined' && subject.subject_name ? subject.subject_name : '') %>"
                                                        placeholder="Enter Subject Name" required>
                                                </div>
                                            </div>

                                            <!-- Status -->
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="status" class="form-label">Status <span class="text-danger">*</span></label>
                                                    <select name="status" id="status" class="form-control" required>
                                                        <option value="">-- Select Status --</option>
                                                        <option value="1" <%= (typeof subject !== 'undefined' && subject.status == 1) || (typeof oldInput !== 'undefined' && oldInput.status == '1') ? 'selected' : '' %>>Active</option>
                                                        <option value="0" <%= (typeof subject !== 'undefined' && subject.status == 0) || (typeof oldInput !== 'undefined' && oldInput.status == '0') ? 'selected' : '' %>>Inactive</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- Is Practical -->
                                            <div class="col-md-6 d-flex align-items-center mt-4">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" name="is_practical" id="is_practical" <%= (typeof oldInput !== 'undefined' ? oldInput.is_practical : (typeof subject !== 'undefined' && subject.is_practical)) ? 'checked' : '' %>>
                                                    <label class="form-check-label fw-bold" for="is_practical">
                                                        Is Practical? (Practical = Yes, Theory = No)
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Submit -->
                                        <div class="mt-4 d-flex justify-content-end">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="bi bi-save me-1"></i> Update Subject
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
</body>
</html>


<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Subjects' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Subjects' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><%= typeof title !== 'undefined' ? title : 'Subjects' %></li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12 col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Subjects' %></h5>
                                        </div>
                                        <div class="col-md-6 d-flex justify-content-end align-items-center">
                                            <a class="btn btn-bg-primary" href="/admin/subjects/create">Add Subject</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle" id="dataTable">
                                            <thead class="table-bg-primary">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Subject Name</th>
                                                    <th>Type</th>
                                                    <th>Course</th>
                                                    <th>Status</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof subjects !== 'undefined' && subjects.length > 0) { %>
                                                    <% subjects.forEach(function(subject, index) { %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><%= subject.subject_name || subject.name || '-' %></td>
                                                            <td>
                                                                <span class="badge <%= (subject.is_practical == 1) ? 'bg-info' : 'bg-secondary' %>">
                                                                    <%= (subject.is_practical == 1) ? 'Practical' : 'Theory' %>
                                                                </span>
                                                            </td>
                                                            <td><%= subject.course && subject.course.name ? subject.course.name : '-' %></td>
                                                            <td>
                                                                <% if (subject.status == '1' || subject.status === 1) { %>
                                                                    <span class="badge bg-success">Active</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-danger">Inactive</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <a href="/admin/subjects/<%= subject.id %>/edit" class="btn btn-sm btn-warning">
                                                                    <i class="bi bi-pencil"></i> Edit
                                                                </a>
                                                                <form action="/admin/subjects/<%= subject.id %>" method="POST" class="d-inline"
                                                                    onsubmit="return confirm('Are you sure you want to delete this subject?');">
                                                                    <input type="hidden" name="_method" value="DELETE">
                                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                                        <i class="bi bi-trash"></i> Delete
                                                                    </button>
                                                                </form>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="5" class="text-center">No subjects found.</td>
                                                    </tr>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
    <%- include('../layouts/datatable_init') %>
</body>
</html>


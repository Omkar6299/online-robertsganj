<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Semesters' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Semesters' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><%= typeof title !== 'undefined' ? title : 'Semesters' %></li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12 col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Semesters' %></h5>
                                        </div>
                                        <div class="col-md-6 d-flex justify-content-end align-items-center">
                                            <a class="btn btn-bg-primary" href="/admin/semesters/create">Add Semester</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <!-- Filter Form -->
                                    <form action="/admin/semesters" method="GET" class="row g-3 mb-4">
                                        <div class="col-md-4">
                                            <label for="course_id" class="form-label">Filter by Course</label>
                                            <select name="course_id" id="course_id" class="form-control">
                                                <option value="">All Courses</option>
                                                <% if (typeof courses !== 'undefined' && courses.length > 0) { %>
                                                    <% courses.forEach(function(course) { %>
                                                        <option value="<%= course.id %>" <%= typeof selectedCourseId !== 'undefined' && selectedCourseId == course.id ? 'selected' : '' %>>
                                                            <%= course.name %>
                                                        </option>
                                                    <% }); %>
                                                <% } %>
                                            </select>
                                        </div>
                                        <div class="col-md-4 d-flex align-items-end">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="bi bi-funnel me-1"></i> Filter
                                            </button>
                                            <% if (typeof selectedCourseId !== 'undefined' && selectedCourseId !== '') { %>
                                                <a href="/admin/semesters" class="btn btn-secondary ms-2">
                                                    <i class="bi bi-x-circle me-1"></i> Clear
                                                </a>
                                            <% } %>
                                        </div>
                                    </form>

                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle" id="dataTable">
                                            <thead class="table-bg-primary">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Semester Name</th>
                                                    <th>Course</th>
                                                    <th>Status</th>
                                                    <th>Registration</th>
                                                    <th>Fee Payment</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof semesters !== 'undefined' && semesters.length > 0) { %>
                                                    <% semesters.forEach(function(semester, index) { %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><%= semester.name %></td>
                                                            <td><%= semester.course && semester.course.name ? semester.course.name : '-' %></td>
                                                            <td>
                                                                <% if (semester.status == 1 || semester.status == '1') { %>
                                                                    <span class="badge bg-success">Active</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-danger">Inactive</span>
                                                                <% } %>
                                                            </td>
                                                            <td class="text-center">
                                                                <% if (semester.registration_enabled == 1 || semester.registration_enabled == '1') { %>
                                                                    <span class="badge bg-primary">
                                                                        <i class="bi bi-check-circle"></i> Enabled
                                                                    </span>
                                                                <% } else { %>
                                                                    <span class="badge bg-secondary">
                                                                        <i class="bi bi-x-circle"></i> Disabled
                                                                    </span>
                                                                <% } %>
                                                            </td>
                                                            <td class="text-center">
                                                                <% if (semester.fee_payment_enabled == 1 || semester.fee_payment_enabled == '1') { %>
                                                                    <span class="badge bg-success">
                                                                        <i class="bi bi-check-circle"></i> Enabled
                                                                    </span>
                                                                <% } else { %>
                                                                    <span class="badge bg-secondary">
                                                                        <i class="bi bi-x-circle"></i> Disabled
                                                                    </span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <a href="/admin/semesters/<%= semester.id %>/edit" class="btn btn-sm btn-warning">
                                                                    <i class="bi bi-pencil"></i> Edit
                                                                </a>
                                                                <form action="/admin/semesters/<%= semester.id %>" method="POST" class="d-inline"
                                                                    onsubmit="return confirm('Are you sure you want to delete this semester?');">
                                                                    <input type="hidden" name="_method" value="DELETE">
                                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                                        <i class="bi bi-trash"></i> Delete
                                                                    </button>
                                                                </form>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } else { %>
                                                    <!-- Empty row - DataTables will show its own empty message -->
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
    <%- include('../layouts/datatable_init') %>
</body>
</html>


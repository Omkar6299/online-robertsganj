<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Users' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Users' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><%= typeof title !== 'undefined' ? title : 'Users' %></li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12 col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Users' %></h5>
                                        </div>
                                        <div class="col-md-6 d-flex justify-content-end align-items-center">
                                            <a class="btn btn-bg-primary" href="/admin/users/create">Add User</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle" id="dataTable">
                                            <thead class="table-bg-primary">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Name</th>
                                                    <th>Email</th>
                                                    <th>Phone</th>
                                                    <th>Role</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof users !== 'undefined' && users.length > 0) { %>
                                                    <% users.forEach(function(user, index) { %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><%= user.name %></td>
                                                            <td><%= user.email %></td>
                                                            <td><%= user.phone || '-' %></td>
                                                            <td><span class="badge bg-info"><%= user.role || 'Student' %></span></td>
                                                            <td>
                                                                <% if (user.role !== 'Super Admin' || (typeof currentUser !== 'undefined' && currentUser.role === 'Super Admin')) { %>
                                                                    <a href="/admin/users/<%= user.id %>/edit" class="btn btn-sm btn-warning">
                                                                        <i class="bi bi-pencil"></i> Edit
                                                                    </a>
                                                                    <form action="/admin/users/<%= user.id %>" method="POST" class="d-inline"
                                                                        onsubmit="return confirm('Are you sure you want to delete this user?');">
                                                                        <input type="hidden" name="_method" value="DELETE">
                                                                        <button type="submit" class="btn btn-sm btn-danger">
                                                                            <i class="bi bi-trash"></i> Delete
                                                                        </button>
                                                                    </form>
                                                                <% } else { %>
                                                                    <span class="text-muted small"><i class="bi bi-lock-fill"></i> Restricted</span>
                                                                <% } %>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="6" class="text-center">No users found.</td>
                                                    </tr>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
    <%- include('../layouts/datatable_init') %>
</body>
</html>


<div class="row align-items-center mb-4 border-bottom pb-3">
    <div class="col-2 text-start">
        <img src="/uploads/static/logo_header.png" alt="Logo Left" style="max-height: 50px;">
    </div>
    <div class="col-8 text-center" style="overflow: hidden;">
        <h6 class="fw-bold mb-1" style="color: #b71c1c; font-size: 13px; white-space: nowrap;">Government Women Degree College Robertsganj Sonebhadra</h6>
        <div class="hindi-title fw-bold mb-1" style="color: #1565c0; font-size: 11px; white-space: nowrap;">राजकीय महिला महाविद्यालय रॉबर्ट्सगंज सोनभद्र</div>
        <div class="affiliation small text-primary" style="font-size: 9px; white-space: nowrap;">Affiliated to Mahatma Gandhi Kashi Vidyapeeth, Varanasi</div>
        <div class="mt-1 fw-bold text-dark" style="font-size: 12px;">FEE CHALLAN</div>
    </div>
    <div class="col-2 text-end">
        <img src="/uploads/static/logo_header_right.png" alt="Logo Right" style="max-height: 50px;">
    </div>
</div>

<% if (typeof challan !== 'undefined' && challan) { %>
    <table class="table table-bordered">
        <tr>
            <th>Challan Number:</th>
            <td><%= challan.challan_no || '-' %></td>
        </tr>
        <tr>
            <th>Registration Number:</th>
            <td><%= challan.registration_no || '-' %></td>
        </tr>
        <tr>
            <th>Student Name:</th>
            <td><%= challan.student_name || '-' %></td>
        </tr>
        <tr>
            <th>Course:</th>
            <td><%= challan.course_name || '-' %></td>
        </tr>
        <tr>
            <th>Amount:</th>
            <td>₹<%= challan.amount || '0' %></td>
        </tr>
        <tr>
            <th>Due Date:</th>
            <td><%= challan.due_date || '-' %></td>
        </tr>
        <tr>
            <th>Status:</th>
            <td>
                <% if (challan.status == 'Paid') { %>
                    <span class="badge bg-success">Paid</span>
                <% } else { %>
                    <span class="badge bg-warning">Pending</span>
                <% } %>
            </td>
        </tr>
    </table>
<% } else { %>
    <div class="alert alert-warning">Challan details not found.</div>
<% } %>


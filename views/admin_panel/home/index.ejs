<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
<div class="app-content-header">
    <!--begin::Container-->
    <div class="container-fluid">
        <!--begin::Row-->
        <div class="row align-items-center">
            <div class="col-sm-6">
                <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h3>
            </div>
            <div class="col-sm-6 text-end">
                <form action="/admin/dashboard" method="GET" class="d-inline-flex align-items-center">
                    <label for="academic_year_id" class="me-2 mb-0 fw-bold text-muted">Academic Session:</label>
                    <select name="academic_year_id" id="academic_year_id" class="form-select form-select-sm w-auto me-2" onchange="this.form.submit()">
                        <% academicYears.forEach(year => { %>
                            <option value="<%= year.id %>" <%= String(year.id) === String(activeYearId) ? 'selected' : '' %>><%= year.session %></option>
                        <% }) %>
                    </select>
                </form>
            </div>
        </div>
        <!--end::Row-->
    </div>
    <!--end::Container-->
</div>
<!--end::App Content Header-->
<!--begin::App Content-->
<div class="app-content">
    <!--begin::Container-->
    <div class="container-fluid">
        <!--begin::Row-->
        <div class="row">
            <!-- 🟡 User Registrations -->
            <div class="col-lg-3 col-6">
                <div class="small-box text-bg-warning">
                    <div class="inner">
                        <h3><%= typeof data !== 'undefined' ? data.formFeeSuccessCount : 0 %></h3>
                        <p>Total Registered</p>
                    </div>
                    <svg class="small-box-icon" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M6.25 6.375a4.125 4.125 0 118.25 0 4.125 4.125 0 01-8.25 0zM3.25 19.125a7.125 7.125 0 0114.25 0v.003l-.001.119a.75.75 0 01-.363.63 13.067 13.067 0 01-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 01-.364-.63l-.001-.122zM19.75 7.5a.75.75 0 00-1.5 0v2.25H16a.75.75 0 000 1.5h2.25v2.25a.75.75 0 001.5 0v-2.25H22a.75.75 0 000-1.5h-2.25V7.5z"></path>
                    </svg>
                </div>
            </div>

            <!-- 🔵 Admitted Students -->
            <div class="col-lg-3 col-6">
                <div class="small-box text-bg-primary">
                    <div class="inner">
                        <h3><%= typeof data !== 'undefined' ? data.admittedStudentCount : 0 %></h3>
                        <p>Admitted Students</p>
                    </div>
                    <svg class="small-box-icon" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M12 3L2 12h3v9h14v-9h3L12 3zm0 4.85L16.15 11H7.85L12 7.85zM7 19v-6.15L12 9.15l5 3.7V19H7z"></path>
                    </svg>
                </div>
            </div>

            <!-- 🟢 Pending Applications -->
            <!-- <div class="col-lg-3 col-6">
                <div class="small-box text-bg-success">
                    <div class="inner">
                        <h3><%= typeof data !== 'undefined' ? data.pendingCount : 0 %></h3>
                        <p>Pending Applications</p>
                    </div>
                    <svg class="small-box-icon" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M11 5a1 1 0 112 0v6.16l3.5 2.02a1 1 0 01-1 1.73l-4-2.31A1 1 0 0111 11.73V5z"></path>
                        <path clip-rule="evenodd" fill-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"></path>
                    </svg>
                </div>
            </div> -->

            <!-- 🔴 Rejected Applications -->
            <div class="col-lg-3 col-6">
                <div class="small-box text-bg-danger">
                    <div class="inner">
                        <h3><%= typeof data !== 'undefined' ? data.rejectedCount : 0 %></h3>
                        <p>Rejected Applications</p>
                    </div>
                    <svg class="small-box-icon" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                        <path d="M15 14c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4zm-9-2V7H4v5H2v2h2v5h2v-5h2v-2H6zm9-2c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4z"></path>
                    </svg>
                </div>
            </div>

            <!-- 💰 Total Form Fees Collected -->
            <div class="col-lg-3 col-6">
                <div class="small-box text-bg-info text-white">
                    <div class="inner">
                        <h3>₹<%= typeof data !== 'undefined' ? Number(data.totalFormFee).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '0.00' %></h3>
                        <p>Total Form Fees Collected</p>
                    </div>
                    <svg class="small-box-icon text-white" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="opacity: 0.3;">
                        <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 14H7v-2h10v2zm0-4H7v-2h10v2zm0-4H7V7h10v2z"></path>
                    </svg>
                </div>
            </div>

            <!-- 💰 Total Admission Fees Collected -->
            <div class="col-lg-3 col-6 mt-3">
                <div class="small-box text-bg-secondary">
                    <div class="inner">
                        <h3>₹<%= typeof data !== 'undefined' ? Number(data.totalAdmissionFee).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) : '0.00' %></h3>
                        <p>Total Admission Fees Collected</p>
                    </div>
                    <svg class="small-box-icon" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="opacity: 0.3;">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 14h-2v-2H9.5a.5.5 0 01-.5-.5v-1a.5.5 0 01.5-.5H11v-1H9.5a.5.5 0 01-.5-.5v-1a.5.5 0 01.5-.5H11V8h2v1h1.5a.5.5 0 01.5.5v1a.5.5 0 01-.5.5H13v1h1.5a.5.5 0 01.5.5v1a.5.5 0 01-.5.5H13v2z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!--end::Row-->
    </div>
    <!--end::Container-->
</div>
<!--end::App Content-->
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Fee Payment Status Report' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Fee Payment Status Report' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Fee Payment Status</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12">
                            <!-- Filter Bar -->
                            <div class="card shadow-sm mb-3">
                                <div class="card-body py-3">
                                    <form action="/admin/fee_payment_report" method="GET" class="row g-3 align-items-end">
                                        <div class="col-md-3">
                                            <label class="form-label mb-1 small fw-semibold">Academic Year</label>
                                            <select name="academic_year_id" class="form-select form-select-sm">
                                                <% if (typeof academicYears !== 'undefined') { academicYears.forEach(function(year) { %>
                                                    <option value="<%= year.id %>" <%= (typeof filters !== 'undefined' && filters.academic_year_id == year.id) ? 'selected' : (typeof activeYearId !== 'undefined' && activeYearId == year.id && !filters.academic_year_id) ? 'selected' : '' %>><%= year.session %></option>
                                                <% }); } %>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label mb-1 small fw-semibold">Course</label>
                                            <select name="course_id" id="repo_course_id" class="form-select form-select-sm" required>
                                                <option value="">-- Select Course --</option>
                                                <% if (typeof courses !== 'undefined') { courses.forEach(function(course) { %>
                                                    <option value="<%= course.id %>" <%= (typeof filters !== 'undefined' && filters.course_id == course.id) ? 'selected' : '' %>><%= course.name %></option>
                                                <% }); } %>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label mb-1 small fw-semibold">Target Semester</label>
                                            <select name="semester_id" id="repo_semester_id" class="form-select form-select-sm" required>
                                                <option value="">-- Select Semester --</option>
                                                <% if (typeof semesters !== 'undefined') { semesters.forEach(function(sem) { %>
                                                    <option value="<%= sem.id %>" data-course="<%= sem.course_id %>" <%= (typeof filters !== 'undefined' && filters.semester_id == sem.id) ? 'selected' : '' %>><%= sem.name %></option>
                                                <% }); } %>
                                            </select>
                                        </div>
                                        <div class="col-md-2">
                                            <label class="form-label mb-1 small fw-semibold">Payment Status</label>
                                            <select name="status" class="form-select form-select-sm">
                                                <option value="All" <%= (typeof filters !== 'undefined' && filters.status === 'All') ? 'selected' : '' %>>All</option>
                                                <option value="Paid" <%= (typeof filters !== 'undefined' && filters.status === 'Paid') ? 'selected' : '' %>>Paid</option>
                                                <option value="Unpaid" <%= (typeof filters !== 'undefined' && filters.status === 'Unpaid') ? 'selected' : '' %>>Unpaid</option>
                                            </select>
                                        </div>
                                        <div class="col-md-1 d-flex gap-1">
                                            <button type="submit" class="btn btn-sm btn-primary w-100">
                                                <i class="bi bi-search"></i>
                                            </button>
                                            <a href="/admin/fee_payment_report" class="btn btn-sm btn-secondary w-100">
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </a>
                                        </div>
                                    </form>
                                    
                                    <script>
                                        document.addEventListener('DOMContentLoaded', function() {
                                            const courseSelect = document.getElementById('repo_course_id');
                                            const semesterSelect = document.getElementById('repo_semester_id');
                                            if (!courseSelect || !semesterSelect) return;
                                            
                                            const originalOptions = Array.from(semesterSelect.options);
                                            
                                            courseSelect.addEventListener('change', function() {
                                                const selectedCourse = this.value;
                                                semesterSelect.innerHTML = '';
                                                semesterSelect.appendChild(originalOptions[0].cloneNode(true));
                                                
                                                originalOptions.slice(1).forEach(opt => {
                                                    if (!selectedCourse || opt.getAttribute('data-course') === selectedCourse) {
                                                        semesterSelect.appendChild(opt.cloneNode(true));
                                                    }
                                                });
                                                
                                                // Retain selection if valid
                                                const currentFiltersSem = "<%= (typeof filters !== 'undefined' && filters.semester_id) ? filters.semester_id : '' %>";
                                                if (currentFiltersSem) {
                                                    semesterSelect.value = currentFiltersSem;
                                                }
                                            });

                                            // Initial trigger if course is selected
                                            if (courseSelect.value) {
                                                const selectedCourse = courseSelect.value;
                                                const currentVal = semesterSelect.value;
                                                semesterSelect.innerHTML = '';
                                                semesterSelect.appendChild(originalOptions[0].cloneNode(true));
                                                originalOptions.slice(1).forEach(opt => {
                                                    if (opt.getAttribute('data-course') === selectedCourse) {
                                                        semesterSelect.appendChild(opt.cloneNode(true));
                                                    }
                                                });
                                                semesterSelect.value = currentVal;
                                            }
                                        });
                                    </script>
                                </div>
                            </div>

                            <!-- Report Table -->
                            <div class="card shadow-sm">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h5 class="mb-0">Students List</h5>
                                    <% if (typeof students !== 'undefined' && students.length > 0) { %>
                                        <span class="badge bg-info">Total: <%= students.length %></span>
                                    <% } %>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle" id="dataTable">
                                            <thead class="table-bg-primary">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Registration No</th>
                                                    <th>Student ID (Common)</th>
                                                    <th>Student Name</th>
                                                    <th>Course</th>
                                                    <th>Current Semester</th>
                                                    <th>Status</th>
                                                    <th>Payment Details</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof students !== 'undefined' && students.length > 0) { %>
                                                    <% students.forEach(function(student, index) { %>
                                                        <% 
                                                            const payment = (student.admissionFeeDetails && student.admissionFeeDetails.length > 0) ? student.admissionFeeDetails[0] : null; 
                                                        %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><strong><%= student.registration_no || '-' %></strong></td>
                                                            <td><span class="badge bg-secondary"><%= student.student_id || '-' %></span></td>
                                                            <td>
                                                                <%= student.user ? student.user.name : '-' %>
                                                                <br>
                                                                <small class="text-muted"><%= student.user ? student.user.phone : '-' %></small>
                                                            </td>
                                                            <td><%= student.courseName ? student.courseName.name : '-' %></td>
                                                            <td><%= student.semsterName ? student.semsterName.name : '-' %></td>
                                                            <td>
                                                                <% if (payment) { %>
                                                                    <span class="badge bg-success">Paid</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-danger">Pending</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <% if (payment) { %>
                                                                    <small>
                                                                        <strong>ID:</strong> <%= payment.merchant_txn_id %><br>
                                                                        <strong>Date:</strong> <%= payment.payment_date ? new Date(payment.payment_date).toLocaleDateString('en-IN') : '-' %>
                                                                    </small>
                                                                <% } else { %>
                                                                    -
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <a href="/admin/students/<%= student.id %>" class="btn btn-sm btn-info" title="View Application">
                                                                    <i class="bi bi-eye"></i>
                                                                </a>
                                                                <% if (payment) { %>
                                                                    <a href="/student/admission_receipt?txn_id=<%= payment.merchant_txn_id %>" target="_blank" class="btn btn-sm btn-success ms-1" title="View Receipt">
                                                                        <i class="bi bi-file-earmark-text"></i>
                                                                    </a>
                                                                <% } %>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } else if (typeof filters !== 'undefined' && filters.semester_id) { %>
                                                    <tr>
                                                        <td colspan="8" class="text-center py-4 text-muted">No students found matching the criteria.</td>
                                                    </tr>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="8" class="text-center py-4 text-muted">Please select a course and semester to generate the report.</td>
                                                    </tr>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
    <%- include('../layouts/datatable_init') %>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Payment Transaction Sync' %></title>
    <style>
        .sync-logs {
            background: #1e1e1e;
            color: #d4d4d4;
            padding: 15px;
            border-radius: 8px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 0.85rem;
            max-height: 400px;
            overflow-y: auto;
            border-left: 4px solid #0f4c81;
        }
        .log-entry { margin-bottom: 5px; }
        .log-time { color: #888; margin-right: 10px; }
        .log-success { color: #4ec9b0; }
        .log-warning { color: #ce9178; }
        .log-error { color: #f44747; }
        .card-glass {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: none;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }
        .text-primary { color: #0f4c81 !important; }
        .btn-primary { background-color: #0f4c81; border-color: #0f4c81; }
        .btn-primary:hover { background-color: #0d3b66; border-color: #0d3b66; }
        .btn-outline-primary { color: #0f4c81; border-color: #0f4c81; }
        .btn-outline-primary:hover { background-color: #0f4c81; color: #fff; }
    </style>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0">Payment Transaction Sync</h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Payment Sync</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-md-5">
                            <div class="card card-glass mb-4">
                                <div class="card-header bg-transparent border-0 pt-4">
                                    <h5 class="card-title text-primary fw-bold">
                                        <i class="bi bi-search me-2"></i>Transaction Query
                                    </h5>
                                </div>
                                <form action="/admin/payments/sync" method="POST" id="syncForm">
                                    <div class="card-body">
                                        <% if (typeof error !== 'undefined' && error) { %>
                                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                                <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Error:</strong> <%= error %>
                                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                            </div>
                                        <% } %>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Merchant Transaction ID</label>
                                            <input type="text" name="merchTxnId" class="form-control form-control-lg" placeholder="e.g. 11000360415944">
                                            <div class="form-text">Primary key from Gateway/Portal.</div>
                                        </div>

                                        <div class="d-flex align-items-center my-3 text-muted">
                                            <hr class="flex-grow-1 m-0">
                                            <span class="px-3 small fw-bold">OR</span>
                                            <hr class="flex-grow-1 m-0">
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Bank RRN</label>
                                            <input type="text" name="rrn" class="form-control" placeholder="e.g. 611116962694">
                                            <div class="form-text">Reference number from Bank Receipt.</div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Transaction Date</label>
                                            <input type="date" name="txnDate" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                                            <div class="form-text">Required for older transactions.</div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Amount (Required)</label>
                                            <input type="number" step="0.01" name="txnAmount" class="form-control" placeholder="e.g. 543.00" required>
                                            <div class="form-text">Exact amount from gateway dashboard.</div>
                                        </div>

                                        <div class="mt-4 p-3 bg-light rounded border">
                                            <h6 class="text-secondary fw-bold mb-3 small"><i class="bi bi-pencil-square me-2"></i>TARGET STUDENT DETAILS</h6>
                                            
                                            <div class="mb-2">
                                                <label class="form-label small fw-bold">Registration No / User ID</label>
                                                <div class="input-group input-group-sm">
                                                    <input type="text" id="target_identifier" class="form-control" placeholder="Reg No or User ID">
                                                    <button class="btn btn-outline-primary" type="button" id="btnSearchStudent"><i class="bi bi-search"></i></button>
                                                </div>
                                                <div id="student_info_box" class="mt-2 small d-none p-2 bg-white border rounded">
                                                    <!-- AJAX content -->
                                                </div>
                                            </div>
                                            
                                            <div class="row g-2 mb-3">
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">User ID</label>
                                                    <input type="number" name="force_user_id" class="form-control form-control-sm" placeholder="User ID">
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">Fee Type</label>
                                                    <select name="force_fee_type" class="form-select form-select-sm">
                                                        <option value="">Auto-detect</option>
                                                        <option value="form_fee">Registration</option>
                                                        <option value="admission_fee">Admission</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="mb-3">
                                                <label class="form-label small fw-bold">Academic Year</label>
                                                <select name="force_academic_year" class="form-select form-select-sm">
                                                    <option value="">Select Year</option>
                                                    <% academicYears.forEach(year => { %>
                                                        <option value="<%= year.id %>"><%= year.session %></option>
                                                    <% }) %>
                                                </select>
                                            </div>

                                            <div class="row g-2">
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">Course</label>
                                                    <select name="force_course_id" id="course_id" class="form-select form-select-sm">
                                                        <option value="">Select Course</option>
                                                        <% courses.forEach(course => { %>
                                                            <option value="<%= course.id %>"><%= course.name %></option>
                                                        <% }) %>
                                                    </select>
                                                </div>
                                                <div class="col-6">
                                                    <label class="form-label small fw-bold">Semester</label>
                                                    <select name="force_semester_id" id="semester_id" class="form-select form-select-sm">
                                                        <option value="">Select Sem</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 pb-4">
                                        <div class="d-grid gap-2">
                                            <button type="submit" name="sync_mode" value="gateway" class="btn btn-primary py-2 shadow-sm fw-bold" id="syncBtn">
                                                <i class="bi bi-arrow-repeat me-2"></i>Fetch & Synchronize
                                            </button>
                                            <button type="submit" name="sync_mode" value="manual" class="btn btn-outline-success py-2 shadow-sm fw-bold">
                                                <i class="bi bi-database-fill-add me-2"></i>Direct Seed (Bypass Gateway)
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="col-md-7">
                            <% if (typeof results !== 'undefined' && results) { %>
                                <div class="card border-0 shadow-sm mb-4 animate__animated animate__fadeIn">
                                    <div class="card-header bg-success text-white py-3">
                                        <h5 class="mb-0"><i class="bi bi-check-circle-fill me-2"></i>Gateway Response</h5>
                                    </div>
                                    <div class="card-body p-0">
                                        <div class="table-responsive">
                                            <table class="table table-hover mb-0">
                                                <tbody>
                                                    <tr>
                                                        <th class="ps-3 bg-light" width="35%">Gateway Status</th>
                                                        <td>
                                                            <span class="badge rounded-pill bg-<%= results.atomResponse.success ? 'success' : 'danger' %>">
                                                                <%= results.atomResponse.success ? 'SUCCESS' : 'FAILED' %>
                                                            </span>
                                                            <strong class="ms-2 text-uppercase"><%= results.atomResponse.statusCode %></strong>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <th class="ps-3 bg-light">Message</th>
                                                        <td><%= results.atomResponse.message %></td>
                                                    </tr>
                                                    <tr>
                                                        <th class="ps-3 bg-light">Paid Amount</th>
                                                        <td class="fs-5 fw-bold text-success">₹<%= results.atomResponse.amount %></td>
                                                    </tr>
                                                    <tr>
                                                        <th class="ps-3 bg-light">Bank RRN</th>
                                                        <td><%= results.atomResponse.bankTxnId || 'N/A' %></td>
                                                    </tr>
                                                    <tr>
                                                        <th class="ps-3 bg-light">Gateway Date</th>
                                                        <td><%= results.atomResponse.txnCompleteDate %></td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>

                                        <div class="p-4">
                                            <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-terminal me-2"></i>Database Update Logs</h6>
                                            <div class="sync-logs">
                                                <% results.logs.forEach(log => { %>
                                                    <div class="log-entry">
                                                        <span class="log-time">[<%= new Date().toLocaleTimeString() %>]</span>
                                                        <span class="log-text <%= log.includes('ERROR') ? 'log-error' : (log.includes('WARNING') ? 'log-warning' : 'log-success') %>">
                                                            <%= log %>
                                                        </span>
                                                    </div>
                                                <% }) %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="card border-0 shadow-sm text-center py-5 px-4 bg-white rounded-3">
                                    <div class="py-5">
                                        <div class="mb-4">
                                            <i class="bi bi-shield-lock-fill text-primary opacity-25" style="font-size: 5rem;"></i>
                                        </div>
                                        <h4 class="fw-bold">Payment Status Bridge</h4>
                                        <p class="text-muted mx-auto" style="max-width: 450px;">
                                            Use this tool to manually reconcile transactions that are successful on the gateway but failed to update in the student records.
                                        </p>
                                        <div class="d-flex justify-content-center gap-3 mt-4">
                                            <span class="badge bg-light text-secondary border px-3 py-2"><i class="bi bi-lightning-fill me-1 text-warning"></i>Real-time</span>
                                            <span class="badge bg-light text-secondary border px-3 py-2"><i class="bi bi-cpu-fill me-1 text-primary"></i>Auto-seeding</span>
                                            <span class="badge bg-light text-secondary border px-3 py-2"><i class="bi bi-lock-fill me-1 text-success"></i>Secure</span>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>

    <script>
        document.getElementById('course_id').addEventListener('change', async function() {
            const courseId = this.value;
            const semesterSelect = document.getElementById('semester_id');
            semesterSelect.innerHTML = '<option value="">...</option>';
            
            if (courseId) {
                try {
                    const response = await fetch(`/admin/fee_maintenance/get-semesters/${courseId}`);
                    const data = await response.json();
                    const semesters = data.semesters || [];
                    
                    semesterSelect.innerHTML = '<option value="">Select Sem</option>';
                    semesters.forEach(sem => {
                        semesterSelect.innerHTML += `<option value="${sem.id}">${sem.name}</option>`;
                    });
                } catch (error) {
                    console.error('Error fetching semesters:', error);
                    semesterSelect.innerHTML = '<option value="">Error</option>';
                }
            } else {
                semesterSelect.innerHTML = '<option value="">Select Sem</option>';
            }
        });

        document.getElementById('syncForm').addEventListener('submit', function() {
            const btn = document.getElementById('syncBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Processing Sync...';
        });

        document.getElementById('btnSearchStudent').addEventListener('click', async function() {
            const identifier = document.getElementById('target_identifier').value;
            const infoBox = document.getElementById('student_info_box');
            
            if (!identifier) return;
            
            this.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            infoBox.classList.add('d-none');
            
            try {
                const response = await fetch(`/admin/payments/fetch-student-details?id=${identifier}`);
                const data = await response.json();
                
                if (data.success) {
                    infoBox.innerHTML = `
                        <div class="fw-bold text-primary">${data.student.user.name}</div>
                        <div class="text-muted">Reg: ${data.student.registration_no || 'N/A'} | User ID: ${data.student.user_id}</div>
                        <div class="text-muted">Course: ${data.student.courseName?.name || 'N/A'}</div>
                        <input type="hidden" name="force_user_id" value="${data.student.user_id}">
                    `;
                    infoBox.classList.remove('d-none');
                } else {
                    infoBox.innerHTML = `<div class="text-danger">Student not found.</div>`;
                    infoBox.classList.remove('d-none');
                }
            } catch (error) {
                console.error('Error:', error);
                infoBox.innerHTML = `<div class="text-danger">Error fetching details.</div>`;
                infoBox.classList.remove('d-none');
            } finally {
                this.innerHTML = '<i class="bi bi-search"></i>';
            }
        });
    </script>
</body>
</html>

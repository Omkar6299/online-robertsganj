<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Course Semesters' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Registration Qualifications' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><%= typeof title !== 'undefined' ? title : 'Registration Qualifications' %></li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12 col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Registration Qualifications' %></h5>
                                        </div>
                                        <div class="col-md-6 d-flex justify-content-end align-items-center">
                                            <form action="/admin/registration_qualifications" method="GET" class="d-flex me-2">
                                                <select name="course_id" class="form-select form-select-sm" onchange="this.form.submit()" style="min-width: 200px;">
                                                    <option value="">-- Filter by Course --</option>
                                                    <% if (typeof courses !== 'undefined' && courses.length > 0) { %>
                                                        <% courses.forEach(function(course) { %>
                                                            <option value="<%= course.id %>" <%= typeof selectedCourseId !== 'undefined' && selectedCourseId == course.id ? 'selected' : '' %>>
                                                                <%= course.name %>
                                                            </option>
                                                        <% }); %>
                                                    <% } %>
                                                </select>
                                                <% if (typeof selectedCourseId !== 'undefined' && selectedCourseId) { %>
                                                    <a href="/admin/registration_qualifications" class="btn btn-sm btn-outline-secondary ms-1" title="Clear Filter">
                                                        <i class="bi bi-x-lg"></i>
                                                    </a>
                                                <% } %>
                                            </form>
                                            <a class="btn btn-bg-primary" href="/admin/registration_qualifications/create">Add Qualifications</a>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-bordered table-hover align-middle" id="dataTable">
                                            <thead class="table-bg-primary">
                                                <tr>
                                                    <th>#</th>
                                                    <th>Course</th>
                                                    <th>Semester</th>
                                                    <th>Status</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (typeof courseSemesters !== 'undefined' && courseSemesters.length > 0) { %>
                                                    <% courseSemesters.forEach(function(cs, index) { %>
                                                        <tr>
                                                            <td><%= index + 1 %></td>
                                                            <td><%= cs.course && cs.course.name ? cs.course.name : '-' %></td>
                                                            <td><%= cs.name ? cs.name : '-' %></td>
                                                            <td>
                                                                <% if (cs.status == '1' || cs.status === 1) { %>
                                                                    <span class="badge bg-success">Active</span>
                                                                <% } else { %>
                                                                    <span class="badge bg-danger">Inactive</span>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <a href="/admin/registration_qualifications/<%= cs.id %>/edit" class="btn btn-sm btn-warning">
                                                                    <i class="bi bi-pencil"></i> Edit
                                                                </a>
                                                                <form action="/admin/registration_qualifications/<%= cs.id %>" method="POST" class="d-inline"
                                                                    onsubmit="return confirm('Are you sure you want to delete this course semester?');">
                                                                    <input type="hidden" name="_method" value="DELETE">
                                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                                        <i class="bi bi-trash"></i> Delete
                                                                    </button>
                                                                </form>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
    <%- include('../layouts/datatable_init') %>
</body>
</html>


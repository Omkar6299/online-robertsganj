<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../layouts/css_link') %>
    <title><%= typeof title !== 'undefined' ? title : 'Edit Course' %></title>
</head>
<body class="layout-fixed fixed-header fixed-footer sidebar-expand-lg sidebar-open sidebar-mini app-loaded bg-body-tertiary">
    <div class="app-wrapper">
        <%- include('../layouts/header') %>
        <%- include('../layouts/sidebar') %>
        <main class="app-main">
            <div class="app-content-header">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6">
                            <h3 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Edit Course' %></h3>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-end">
                                <li class="breadcrumb-item"><a href="/admin/dashboard">Home</a></li>
                                <li class="breadcrumb-item"><a href="/admin/courses">Courses</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><%= typeof title !== 'undefined' ? title : 'Edit Course' %></li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>

            <div class="app-content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-12 col-md-12">
                            <div class="card shadow-sm">
                                <div class="card-header">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h5 class="mb-0"><%= typeof title !== 'undefined' ? title : 'Edit Course' %></h5>
                                        </div>
                                        <div class="col-md-6 d-flex justify-content-end align-items-center">
                                            <a class="btn btn-bg-primary" href="/admin/courses">Return</a>
                                        </div>
                                    </div>
                                </div>

                                <div class="card-body">
                                    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                                        <div class="alert alert-danger">
                                            <ul class="mb-0">
                                                <% errors.forEach(function(error) { %>
                                                    <li><%= error %></li>
                                                <% }); %>
                                            </ul>
                                        </div>
                                    <% } %>

                                    <form action="/admin/courses/<%= typeof course !== 'undefined' ? course.id : '' %>" method="POST">
                                        <input type="hidden" name="_method" value="PUT">
                                        <div class="row g-3">
                                            <!-- Course Type -->
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="course_type_id" class="form-label">Course Type <span class="text-danger">*</span></label>
                                                    <select name="course_type_id" id="course_type_id" class="form-control <%= typeof errors !== 'undefined' && errors.some(e => e.includes('course_type_id')) ? 'is-invalid' : '' %>" required>
                                                        <option value="">-- Select Course Type --</option>
                                                        <% if (typeof courseType !== 'undefined' && courseType.length > 0) { %>
                                                            <% courseType.forEach(function(type) { %>
                                                                <option value="<%= type.id %>" <%= (typeof course !== 'undefined' && course.course_type_id == type.id) || (typeof oldInput !== 'undefined' && oldInput.course_type_id == type.id) ? 'selected' : '' %>>
                                                                    <%= type.name %>
                                                                </option>
                                                            <% }); %>
                                                        <% } %>
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- Course Name -->
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="course_name" class="form-label">Course Name <span class="text-danger">*</span></label>
                                                    <input type="text" name="course_name" id="course_name"
                                                        value="<%= typeof oldInput !== 'undefined' && oldInput.course_name ? oldInput.course_name : (typeof course !== 'undefined' ? course.name : '') %>"
                                                        class="form-control <%= typeof errors !== 'undefined' && errors.some(e => e.includes('course_name')) ? 'is-invalid' : '' %>"
                                                        placeholder="Enter Course Name" required>
                                                </div>
                                            </div>

                                            <!-- Status -->
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label for="status" class="form-label">Status <span class="text-danger">*</span></label>
                                                    <select name="status" id="status" class="form-control <%= typeof errors !== 'undefined' && errors.some(e => e.includes('status')) ? 'is-invalid' : '' %>" required>
                                                        <option value="">-- Select Status --</option>
                                                        <option value="1" <%= (typeof course !== 'undefined' && course.status == 1) || (typeof oldInput !== 'undefined' && oldInput.status == '1') ? 'selected' : '' %>>Active</option>
                                                        <option value="0" <%= (typeof course !== 'undefined' && course.status == 0) || (typeof oldInput !== 'undefined' && oldInput.status == '0') ? 'selected' : '' %>>Inactive</option>
                                                    </select>
                                                </div>
                                            </div>

                                        </div>

                                        <!-- Submit -->
                                        <div class="mt-4 d-flex justify-content-end">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="bi bi-save me-1"></i> Update Course
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <%- include('../layouts/footer') %>
    </div>
    <%- include('../layouts/script_link') %>
</body>
</html>

